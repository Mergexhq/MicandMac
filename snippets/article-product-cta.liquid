{% comment %}
  Snippet: article-product-cta
  Usage: {% render 'article-product-cta', product: article.metafields.custom.featured_product.value %}
  Mid-article product callout card
{% endcomment %}

{%- if product != blank -%}
  <div class="article-product-cta">
    {%- if product.featured_image -%}
      <img
        src="{{ product.featured_image | image_url: width: 200 }}"
        alt="{{ product.title }}"
        width="100"
        height="100"
        loading="lazy"
        class="article-product-cta__img"
      >
    {%- endif -%}
    <div class="article-product-cta__content">
      <p class="eyebrow" style="color: var(--color-gold)">Featured in this article</p>
      <h4 class="article-product-cta__title">{{ product.title }}</h4>
      {% render 'price', variant: product.selected_or_first_available_variant %}
    </div>
    <a href="{{ product.url }}" class="btn btn--primary btn--sm article-product-cta__btn">
      Shop Now
    </a>
  </div>
{%- endif -%}

<style>
.article-product-cta {
  display: flex;
  align-items: center;
  gap: var(--space-5);
  padding: var(--space-5) var(--space-6);
  background: var(--color-cream);
  border-left: 4px solid var(--color-gold);
  border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  margin-block: var(--space-8);
  flex-wrap: wrap;
}

.article-product-cta__img {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md);
  object-fit: cover;
  background: var(--color-beige);
  flex-shrink: 0;
}

.article-product-cta__content {
  flex: 1;
  min-width: 200px;
}

.article-product-cta__title {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 400;
  color: var(--color-text-dark);
  margin-block: var(--space-1) var(--space-2);
}

.article-product-cta__btn { flex-shrink: 0; }
</style>
