{% comment %}
  Snippet: star-rating
  Usage: {% render 'star-rating', rating: 4.5, count: 128, size: 'sm' %}
  Params:
    - rating: number 0–5 (required)
    - count:  review count label (optional)
    - size:   'sm' | 'md' | 'lg' (optional, default 'sm')
{% endcomment %}

{%- liquid
  assign rating = rating | default: 0
  assign size   = size   | default: 'sm'
  assign full   = rating | floor
  assign remainder = rating | minus: full
  assign has_half = false
  if remainder >= 0.25 and remainder < 0.75
    assign has_half = true
  elsif remainder >= 0.75
    assign full = full | plus: 1
  endif
  assign empty = 5 | minus: full
  if has_half
    assign empty = empty | minus: 1
  endif
-%}

<div
  class="star-rating star-rating--{{ size }}"
  aria-label="{{ rating | round: 1 }} out of 5 stars"
  role="img"
>
  {%- comment %} Filled stars {%- endcomment %}
  {%- for i in (1..full) -%}
    <svg class="star star--filled" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
    </svg>
  {%- endfor -%}

  {%- comment %} Half star {%- endcomment %}
  {%- if has_half -%}
    <svg class="star star--half" viewBox="0 0 24 24" aria-hidden="true">
      <defs>
        <linearGradient id="half-grad-{{ section.id }}">
          <stop offset="50%" stop-color="currentColor"/>
          <stop offset="50%" stop-color="transparent"/>
        </linearGradient>
      </defs>
      <path
        d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
        fill="url(#half-grad-{{ section.id }})"
        stroke="currentColor"
        stroke-width="1"
      />
    </svg>
  {%- endif -%}

  {%- comment %} Empty stars {%- endcomment %}
  {%- if empty > 0 -%}
    {%- for i in (1..empty) -%}
      <svg class="star star--empty" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {%- endfor -%}
  {%- endif -%}

  {%- if count != blank and count != nil -%}
    <span class="star-rating__count">({{ count }})</span>
  {%- endif -%}
</div>

<style>
.star-rating {
  display: inline-flex;
  align-items: center;
  gap: 1px;
  color: var(--color-gold);
  line-height: 1;
}

/* Sizes */
.star-rating--sm .star { width: 12px; height: 12px; }
.star-rating--md .star { width: 16px; height: 16px; }
.star-rating--lg .star { width: 20px; height: 20px; }

.star { flex-shrink: 0; }

.star-rating__count {
  font-size: var(--text-xs);
  color: var(--color-text-light);
  margin-left: var(--space-1);
  font-family: var(--font-body);
}
</style>
