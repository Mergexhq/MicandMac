{% comment %}
  Snippet: account-nav
  Usage: {% render 'account-nav', current: 'orders' %}
  Minimalist text-only sidebar navigation. No icons.
{% endcomment %}

{%- assign current = current | default: 'orders' -%}

<nav class="account-nav" aria-label="Account navigation">

  <p class="account-nav__greeting">Hi, <em>{{ customer.first_name }}</em></p>
  <hr class="account-nav__rule">

  <ul class="account-nav__list">
    <li>
      <a
        href="{{ routes.account_url }}"
        class="account-nav__link {% if current == 'orders' or current == 'dashboard' %}is-active{% endif %}"
      >Orders</a>
    </li>
    <li>
      <a
        href="{{ routes.account_addresses_url }}"
        class="account-nav__link {% if current == 'addresses' %}is-active{% endif %}"
      >Addresses</a>
    </li>
    <li>
      <a
        href="/pages/wishlist"
        class="account-nav__link {% if current == 'wishlist' %}is-active{% endif %}"
      >Wishlist</a>
    </li>
    <li>
      <a
        href="{{ routes.account_url }}?section=details"
        class="account-nav__link {% if current == 'details' %}is-active{% endif %}"
      >Account Details</a>
    </li>
  </ul>

  <hr class="account-nav__rule">

  <a href="{{ routes.account_logout_url }}" class="account-nav__link account-nav__link--logout">
    Log out
  </a>

</nav>
