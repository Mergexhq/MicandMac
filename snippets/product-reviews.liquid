{% comment %}
  Snippet: product-reviews
  Usage: {% render 'product-reviews', product: product %}
  Rating summary + breakdown bars + review list.
  Plugs into Judge.me / Okendo via embed target #JudgemeReviews or #OkendoReviews.
  Falls back to metafield-based manual display if no app installed.
{% endcomment %}

{%- liquid
  assign avg_rating = product.metafields.reviews.rating.value
  assign review_count = product.metafields.reviews.rating_count.value | plus: 0
-%}

<div class="product-reviews" id="ProductReviews">

  <!-- Summary header -->
  {%- if avg_rating != blank -%}
    <div class="product-reviews__summary">
      <div class="product-reviews__score">
        <span class="product-reviews__avg">{{ avg_rating | round: 1 }}</span>
        {% render 'star-rating', rating: avg_rating, size: 'lg' %}
        <span class="product-reviews__count">{{ review_count }} reviews</span>
      </div>
    </div>
  {%- endif -%}

  <!-- App embed targets (uncomment the one you're using) -->
  <!-- Judge.me: -->
  <div id="JudgemeReviews" class="product-reviews__app-embed" data-product-id="{{ product.id }}">
    <!-- Judge.me widget renders here -->
  </div>

  <!-- Fallback: no app installed -->
  {%- if avg_rating == blank -%}
    <div class="product-reviews__empty">
      <p>Be the first to review this product.</p>
      <a href="mailto:hello@micandmac.in?subject=Review: {{ product.title | url_encode }}" class="btn btn--secondary btn--sm">
        Write a Review
      </a>
    </div>
  {%- endif -%}

</div>

<style>
.product-reviews {
  padding-top: var(--space-8);
  border-top: 1px solid var(--color-beige);
  margin-top: var(--space-8);
}

.product-reviews__summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
  padding-bottom: var(--space-6);
  border-bottom: 1px solid var(--color-beige);
}

.product-reviews__score {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.product-reviews__avg {
  font-family: var(--font-display);
  font-size: var(--text-5xl);
  font-weight: 400;
  color: var(--color-text-dark);
  line-height: 1;
}

.product-reviews__count {
  font-size: var(--text-sm);
  color: var(--color-text-light);
}

.product-reviews__empty {
  text-align: center;
  padding: var(--space-10);
  color: var(--color-text-light);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
}

.product-reviews__app-embed {
  min-height: 60px;
}
</style>
