{% comment %}
  Snippet: product-reviews
  A high-conversion social proof engine capturing rich zero-party data.
  Usage: {% render 'product-reviews', product: product %}
{% endcomment %}

{%- style -%}
  .pdp-reviews-system {
    width: 100%;
    margin-top: 2rem;
    font-family: var(--font-body-family, sans-serif);
    color: var(--color-text-primary, #1a1a1a);
  }

  .rev-header {
    margin-bottom: 2rem;
  }

  .rev-title {
    font-family: var(--font-heading-family, serif);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    text-transform: capitalize;
  }

  /* Summary Block (only if >=3 reviews) */
  .rev-summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    background: #faf9f6;
    padding: 1.5rem;
    border-radius: 12px;
  }

  .rev-summary__score {
    font-family: var(--font-heading-family, serif);
    font-size: 3rem;
    line-height: 1;
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .rev-summary__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .rev-summary__stars {
    color: #000;
    font-size: 1.125rem;
    letter-spacing: 2px;
  }

  .rev-summary__text {
    font-size: 0.875rem;
    color: #666;
  }

  .rev-summary__recommend {
    width: 100%;
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Empty State / Exclusivity State */
  .rev-empty {
    background: #fbfbfb;
    border: 1px dashed #d9d9d9;
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .rev-empty__main {
    font-family: var(--font-heading-family, serif);
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 8px;
    color: #111;
  }

  .rev-empty__sub {
    font-size: 0.9375rem;
    color: #666;
    margin-bottom: 1.5rem;
  }

  /* CTA Button */
  .rev-cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #111;
    color: #fff;
    padding: 12px 24px;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .rev-cta-btn:hover { background: #333; }

  /* Review Form */
  .rev-form-wrapper {
    max-width: 600px;
    margin: 0 auto 3rem auto;
  }
  .rev-form-container {
    display: none; /* hidden by default, toggled via JS */
    background: #F8F5F2; /* Soft background */
    border-radius: 12px;
    padding: 3rem 2rem;
  }
  .rev-form-container.is-open { display: block; }
  
  .rev-form-intro {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .rev-form-intro h3 {
    font-family: var(--font-heading-family, serif);
    font-size: 1.75rem;
    margin-bottom: 8px;
    color: #111;
  }
  .rev-form-intro p {
    font-size: 0.9375rem;
    color: #555;
  }

  .rev-form-fields {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .rev-input, .rev-textarea {
    width: 100%;
    padding: 14px 16px;
    border: none;
    border-bottom: 1px solid #ddd;
    background: transparent;
    font-size: 1rem;
    font-family: inherit;
    color: #111;
    transition: border-color 0.2s;
  }
  .rev-input:focus, .rev-textarea:focus {
    outline: none;
    border-bottom-color: #111;
  }
  .rev-textarea {
    resize: vertical;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: #fff;
  }
  .rev-textarea:focus {
    border-color: #111;
  }

  .rev-stars-input {
    display: flex;
    justify-content: center;
    gap: 12px;
    font-size: 2.5rem;
    color: #ddd;
    cursor: pointer;
    margin-bottom: 0.5rem;
    line-height: 1;
  }
  .rev-stars-input span { transition: color 0.2s ease; }
  .rev-stars-input span:hover, .rev-stars-input span.active { color: #000; }

  /* Photo Upload UI */
  .rev-upload-area {
    display: block;
    border: 1px dashed #ccc;
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
    background: #fff;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .rev-upload-area:hover {
    border-color: #111;
  }
  .rev-upload-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    color: #555;
    cursor: pointer;
  }
  .rev-upload-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  /* Optional Expand */
  .rev-expand-btn {
    background: none;
    border: none;
    color: #555;
    font-size: 0.875rem;
    text-decoration: underline;
    cursor: pointer;
    padding: 0;
    margin-top: -1rem;
    text-align: left;
    width: fit-content;
  }
  .rev-expanded-fields {
    display: none;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .rev-expanded-fields { grid-template-columns: 1fr 1fr; }
  }
  .rev-expanded-fields.is-visible {
    display: grid;
  }

  /* Dropdowns */
  select.rev-input {
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 8px;
    padding: 14px 16px;
    appearance: none;
  }

  /* Submit Button */
  .rev-submit-btn {
    background: #111;
    color: #fff;
    padding: 16px;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s;
    width: 100%;
    margin-top: 1rem;
  }
  .rev-submit-btn:hover { background: #333; }

  /* Success State */
  .rev-success-msg {
    text-align: center;
    padding: 2rem 1rem;
  }
  .rev-success-msg h4 {
    font-family: var(--font-heading-family, serif);
    font-size: 1.5rem;
    margin-bottom: 8px;
    color: #111;
  }
  .rev-success-msg p {
    color: #555;
    font-size: 1rem;
  }

  /* Review Cards List */
  .rev-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .rev-card {
    border-bottom: 1px solid #eaeaea;
    padding-bottom: 2rem;
  }
  .rev-card:last-child {
    border-bottom: none;
  }

  .rev-card__header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 12px;
  }

  .rev-card__stars {
    color: #000;
    letter-spacing: 2px;
    font-size: 1rem;
  }

  .rev-card__title {
    font-family: var(--font-heading-family, serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: #111;
  }

  .rev-card__meta {
    font-size: 0.75rem;
    color: #777;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .rev-card__body {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #444;
    margin-bottom: 12px;
  }

  .rev-card__footer {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: #111;
    font-weight: 500;
  }

  .rev-card__verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: #2d8a39;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .rev-card__verified svg { width: 12px; height: 12px; }

{%- endstyle -%}

{%- liquid
  assign avg_rating = product.metafields.reviews.rating.value | default: 0.0
  assign review_count = product.metafields.reviews.rating_count.value | plus: 0
  
  assign has_summary = false
  if review_count >= 3
    assign has_summary = true
  endif
-%}

<div class="pdp-reviews-system" id="RealExperiences">
  <div class="rev-header">
    <h2 class="rev-title">Real Experiences</h2>

    {%- if has_summary -%}
      <!-- High-Trust Summary Block (Only shown if 3+ reviews) -->
      <div class="rev-summary">
        <div class="rev-summary__score">{{ avg_rating | round: 1 }}</div>
        <div class="rev-summary__meta">
          <div class="rev-summary__stars">
            {%- for i in (1..5) -%}★{%- endfor -%}
          </div>
          <div class="rev-summary__text">Based on {{ review_count }} reviews</div>
        </div>
        <div class="rev-summary__recommend">
          ✔️ 100% recommend this product
        </div>
      </div>
      
      <!-- Sticky CTA when populated -->
      <div style="margin-bottom: 2rem;">
        <button type="button" class="rev-cta-btn" onclick="document.getElementById('RevForm').classList.toggle('is-open')">
          Share your experience
        </button>
      </div>

    {%- else -%}
      <!-- Exclusivity / Early Access Empty State -->
      <div class="rev-empty">
        <div class="rev-empty__main">Be the first to experience this formula.</div>
        <div class="rev-empty__sub">Your feedback helps others choose better.</div>
        <button type="button" class="rev-cta-btn" onclick="document.getElementById('RevForm').classList.toggle('is-open')">
          Share your experience
        </button>
      </div>
    {%- endif -%}
  </div>

  <!-- Review Generation Form -->
  <div class="rev-form-wrapper">
    <div class="rev-form-container" id="RevForm">
      
      <div class="rev-form-intro" id="RevFormIntro">
        <h3>Join others who’ve tried this product.</h3>
        <p>Your experience matters.</p>
      </div>
      
      {% form 'contact', id: 'ProductReviewForm' %}
        {% if form.posted_successfully? %}
          <div class="rev-success-msg">
            <h4>Thank you for sharing.</h4>
            <p>Your feedback helps others choose better.</p>
          </div>
          <script>
            document.getElementById('RevForm').classList.add('is-open');
            if(document.getElementById('RevFormIntro')) {
              document.getElementById('RevFormIntro').style.display = 'none';
            }
          </script>
        {% endif %}
        
        {% unless form.posted_successfully? %}
          {{ form.errors | default_errors }}
          
          <div class="rev-form-fields">
            <!-- Rating -->
            <div style="text-align: center;">
              <div class="rev-stars-input" id="StarSelector">
                <span data-val="1">★</span><span data-val="2">★</span><span data-val="3">★</span><span data-val="4">★</span><span data-val="5">★</span>
              </div>
              <input type="hidden" name="contact[rating]" id="ReviewRatingValue" value="">
            </div>

            <!-- Review Textarea -->
            <div>
              <textarea rows="4" class="rev-textarea" id="RevBody" name="contact[review_body]" placeholder="How did it feel on your skin?"></textarea>
            </div>

            <!-- Image Upload UI -->
            <div>
              <input type="file" id="RevPhoto" accept="image/jpeg, image/png" multiple style="display: none;" onchange="handleFileUpload(event)">
              <label for="RevPhoto" class="rev-upload-area" id="RevUploadArea">
                <div class="rev-upload-label">
                  <span class="rev-upload-icon">+</span>
                  <span style="font-weight: 500; color: #111;">Add Photo</span>
                  <span style="font-size: 0.8125rem;">Drag & drop or upload (Max 3)</span>
                </div>
              </label>
              <div id="RevPhotoPreview" style="display: flex; gap: 12px; margin-top: 12px; flex-wrap: wrap;"></div>
            </div>

            <!-- Name Field -->
            <div>
              <input type="text" class="rev-input" style="border: 1px solid #ddd; background: #fff; border-radius: 8px;" id="RevName" name="contact[first_name]" placeholder="Your name (optional)">
            </div>
            
            <!-- Expandable Details -->
            <button type="button" class="rev-expand-btn" id="RevExpandBtn" onclick="toggleReviewDetails()">+ Add more details</button>
            
            <div class="rev-expanded-fields" id="RevExpandedFields">
              <div>
                <select class="rev-input" id="RevSkin" name="contact[skin_type]">
                  <option value="" disabled selected>Skin Type (Optional)</option>
                  <option value="Oily">Oily</option>
                  <option value="Dry">Dry</option>
                  <option value="Combination">Combination</option>
                  <option value="Sensitive">Sensitive</option>
                  <option value="Normal">Normal</option>
                </select>
              </div>
              <div>
                <select class="rev-input" id="RevDuration" name="contact[usage_duration]">
                  <option value="" disabled selected>Usage duration (Optional)</option>
                  <option value="&lt; 1 week">&lt; 1 week</option>
                  <option value="1-2 weeks">1-2 weeks</option>
                  <option value="1 month+">1 month+</option>
                </select>
              </div>
            </div>
            
            <!-- Hidden Fields for Shopify Form / Context -->
            <input type="email" name="contact[email]" style="display:none;" value="review_{{ 'now' | date: '%s' }}@anonymous.com">
            <input type="hidden" name="contact[product]" value="{{ product.title }}">
            
            <button type="submit" class="rev-submit-btn" id="ReviewSubmitBtn">Share your experience</button>
          </div>
        {% endunless %}
      {% endform %}
      
      <script>
        // Toggle Expanded Details
        function toggleReviewDetails() {
          const fields = document.getElementById('RevExpandedFields');
          const btn = document.getElementById('RevExpandBtn');
          if (fields.classList.contains('is-visible')) {
            fields.classList.remove('is-visible');
            btn.innerText = '+ Add more details';
          } else {
            fields.classList.add('is-visible');
            btn.innerText = '- Hide details';
          }
        }

        // Handle Image Upload UI
        function handleFileUpload(event) {
          const files = Array.from(event.target.files);
          const preview = document.getElementById('RevPhotoPreview');
          preview.innerHTML = ''; // Basic implementation, overwrites previous selection

          const validFiles = files.slice(0, 3); // Max 3 images
          
          validFiles.forEach(file => {
            if (!file.type.match('image/jpeg') && !file.type.match('image/png')) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
              const imgContainer = document.createElement('div');
              imgContainer.style.width = '72px';
              imgContainer.style.height = '72px';
              imgContainer.style.borderRadius = '8px';
              imgContainer.style.overflow = 'hidden';
              imgContainer.style.border = '1px solid #eaeaea';
              imgContainer.style.backgroundColor = '#f4f4f4';
              imgContainer.style.flexShrink = '0';
              
              const img = document.createElement('img');
              img.src = e.target.result;
              img.style.width = '100%';
              img.style.height = '100%';
              img.style.objectFit = 'cover';
              img.style.display = 'block';
              
              imgContainer.appendChild(img);
              preview.appendChild(imgContainer);
            }
            reader.readAsDataURL(file);
          });
        }

        // Stars Logic
        document.addEventListener('DOMContentLoaded', function() {
          const stars = document.querySelectorAll('#StarSelector span');
          const ratingInput = document.getElementById('ReviewRatingValue');
          
          stars.forEach(star => {
            star.addEventListener('click', function() {
              const val = parseInt(this.getAttribute('data-val'));
              ratingInput.value = val;
              
              stars.forEach(s => {
                if(parseInt(s.getAttribute('data-val')) <= val) {
                  s.style.color = '#000';
                } else {
                  s.style.color = '#ddd';
                }
              });
            });
          });

          // Validation & SessionStorage
          const form = document.getElementById('ProductReviewForm');
          if(form) {
            form.addEventListener('submit', function(e) {
              const body = document.getElementById('RevBody')?.value.trim();
              const rating = document.getElementById('ReviewRatingValue')?.value;
              
              // Mandatory rule: Rating OR Text must be present
              if(!body && !rating) {
                e.preventDefault();
                alert('Please leave a rating or write your experience before submitting.');
                return;
              }

              // Save to sessionStorage for optimistic UI addition
              const tempReview = {
                title: 'Review',
                body: body,
                name: document.getElementById('RevName')?.value || 'Anonymous',
                skin: document.getElementById('RevSkin')?.value || 'Not specified',
                duration: document.getElementById('RevDuration')?.value || 'Not specified',
                rating: rating || 5
              };
              sessionStorage.setItem('temp_user_review', JSON.stringify(tempReview));
            });
          }
        });
      </script>
    </div>
  </div>

  <!-- Real Reviews List -->
  <div class="rev-list" id="RevListContainer">
    
    <script>
      // If we just successfully posted, inject the saved review from sessionStorage
      document.addEventListener('DOMContentLoaded', function() {
        {% if form.posted_successfully? %}
          const savedStr = sessionStorage.getItem('temp_user_review');
          if (savedStr) {
            try {
              const r = JSON.parse(savedStr);
              const starsHtml = '★★★★★☆☆☆☆☆'.substring(5 - parseInt(r.rating || 5), 10 - parseInt(r.rating || 5)); 
              const html = `
                <div class="rev-card" style="animation: fade-in 1s ease;">
                  <div class="rev-card__header">
                    <div class="rev-card__stars">${starsHtml}</div>
                    <h4 class="rev-card__title">${r.title || 'In Review'} <span style="background: #fdf2e9; color: #e67e22; font-size: 0.65rem; padding: 2px 6px; border-radius: 4px; vertical-align: middle; margin-left: 8px; text-transform: uppercase; letter-spacing: 0.05em;">Pending</span></h4>
                  </div>
                  <div class="rev-card__meta">
                    Skin Type: ${r.skin} <span>|</span> Used for ${r.duration}
                  </div>
                  <p class="rev-card__body">"${r.body}"</p>
                  <div class="rev-card__footer">
                    — ${r.name}
                  </div>
                </div>
              `;
              const listContainer = document.getElementById('RevListContainer');
              if (listContainer) {
                listContainer.insertAdjacentHTML('afterbegin', html);
              }
            } catch (e) {}
          }
        {% endif %}
      });
    </script>
    
    {%- comment -%} 
      Because there are no metafields returning arrays in standard Shopify admin without an app, 
      I am mapping out the HTML structure so you can see it and manually populate custom metafields 
      or migrate beautifully once an app is hooked in.
    {%- endcomment -%}

    {%- if product.metafields.custom.review_1 != blank -%}
      <div class="rev-card">
        <div class="rev-card__header">
          <div class="rev-card__stars">★★★★★</div>
          <h4 class="rev-card__title">{{ product.metafields.custom.review_1_title | default: "Visible results" }}</h4>
        </div>
        <div class="rev-card__meta">
          Skin Type: {{ product.metafields.custom.review_1_skin | default: "Combination" }} <span>|</span> 
          Used for {{ product.metafields.custom.review_1_duration | default: "1-2 weeks" }}
        </div>
        <p class="rev-card__body">"{{ product.metafields.custom.review_1 }}"</p>
        <div class="rev-card__footer">
          — {{ product.metafields.custom.reviewer_1 | default: 'Verified Customer' }}
          <span class="rev-card__verified">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
            Verified Purchase
          </span>
        </div>
      </div>
    {%- endif -%}

    {%- if product.metafields.custom.review_2 != blank -%}
      <div class="rev-card">
        <div class="rev-card__header">
          <div class="rev-card__stars">★★★★★</div>
          <h4 class="rev-card__title">{{ product.metafields.custom.review_2_title | default: "Highly recommend" }}</h4>
        </div>
        <div class="rev-card__meta">
          Skin Type: {{ product.metafields.custom.review_2_skin | default: "Oily" }} <span>|</span> 
          Used for {{ product.metafields.custom.review_2_duration | default: "1 month+" }}
        </div>
        <p class="rev-card__body">"{{ product.metafields.custom.review_2 }}"</p>
        <div class="rev-card__footer">
          — {{ product.metafields.custom.reviewer_2 | default: 'Verified Customer' }}
          <span class="rev-card__verified">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
            Verified Purchase
          </span>
        </div>
      </div>
    {%- endif -%}

  </div>

</div>
