{% comment %}
  Snippet: product-reviews
  Powered by Judge.me
{% endcomment %}

{%- style -%}
  .pdp-reviews-system {
    width: 100%;
    margin-top: 2rem;
    font-family: var(--font-body-family, sans-serif);
    color: var(--color-text-primary, #1a1a1a);
  }

  .rev-header {
    margin-bottom: 2rem;
  }

  .rev-title {
    font-family: var(--font-heading-family, serif);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    text-transform: capitalize;
  }

  /* Judge.me Color Overrides */
  .pdp-reviews-system,
  .jdgm-widget {
    --jdgm-primary-color: var(--mm-deep-garnet, #4B2A31) !important;
  }

  .pdp-reviews-system .jdgm-star,
  .pdp-reviews-system .jdgm-rev__icon,
  .pdp-reviews-system .jdgm-sort-dropdown,
  .pdp-reviews-system .jdgm-cancel-rev,
  .pdp-reviews-system .jdgm-rev__author {
    color: var(--mm-deep-garnet, #4B2A31) !important;
  }
  
  .pdp-reviews-system .jdgm-write-rev-link,
  .pdp-reviews-system .jdgm-submit-rev,
  .pdp-reviews-system .jdgm-rev__buyer-badge,
  .pdp-reviews-system .jdgm-histogram__bar-content {
    background-color: var(--mm-deep-garnet, #4B2A31) !important;
    color: #fff !important;
  }

  .pdp-reviews-system .jdgm-write-rev-link,
  .pdp-reviews-system .jdgm-submit-rev {
    border: 1px solid var(--mm-deep-garnet, #4B2A31) !important;
    border-radius: var(--radius-sm, 4px) !important;
    transition: background 0.2s ease, transform 0.2s ease, border-color 0.2s ease !important;
  }

  /* Form focus borders */
  .pdp-reviews-system .jdgm-form input:focus,
  .pdp-reviews-system .jdgm-form textarea:focus,
  .pdp-reviews-system input.jdgm-form__review-title:focus,
  .pdp-reviews-system textarea.jdgm-form__review-body:focus {
    border-color: var(--mm-deep-garnet, #4B2A31) !important;
    box-shadow: 0 0 0 1px var(--mm-deep-garnet, #4B2A31) !important;
    outline: none !important;
  }

  /* Checkmarks and badges */
  .pdp-reviews-system .jdgm-rev__buyer-badge-icon,
  .pdp-reviews-system .jdgm-rev__icon::after {
    color: var(--mm-deep-garnet, #4B2A31) !important;
    background-color: transparent !important;
  }
  
  .pdp-reviews-system svg path[fill="#11c49b"],
  .pdp-reviews-system svg path[fill="#0c9f7d"],
  .pdp-reviews-system svg path[stroke="#11c49b"],
  .pdp-reviews-system .jdgm-rev-widg__summary-text svg path,
  .pdp-reviews-system .jdgm-verified-badge svg path,
  .pdp-reviews-system .jdgm-rev__buyer-badge-icon svg path,
  .pdp-reviews-system .jdgm-rev__icon::after svg path {
    fill: var(--mm-deep-garnet, #4B2A31) !important;
    stroke: var(--mm-deep-garnet, #4B2A31) !important;
  }
  
  .pdp-reviews-system .jdgm-verified-badge {
    color: var(--mm-deep-garnet, #4B2A31) !important;
  }
  
  .pdp-reviews-system .jdgm-write-rev-link:hover,
  .pdp-reviews-system .jdgm-submit-rev:hover {
    background-color: var(--mm-dark-espresso, #2E1F1A) !important;
    border-color: var(--mm-dark-espresso, #2E1F1A) !important;
    transform: translateY(-1px);
  }

  .pdp-reviews-system .jdgm-paginate__page {
    color: var(--mm-deep-garnet, #4B2A31) !important;
  }
{%- endstyle -%}

<div class="pdp-reviews-system" id="RealExperiences">
  <div class="rev-header">
    <h2 class="rev-title">Real Experiences</h2>
  </div>

  {%- render 'judgeme_widgets', widget_type: 'judgeme_product_reviews', concierge_install: true, product: product -%}
</div>
