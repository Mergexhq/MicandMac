{% comment %}
  Snippet: wishlist-guest-nudge
  Shown to guests to encourage account creation
{% endcomment %}

<div class="wishlist-nudge">
  <div class="wishlist-nudge__icon" aria-hidden="true">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
  </div>
  <h3 class="wishlist-nudge__title">Save your favourites</h3>
  <p class="wishlist-nudge__text">Create an account to sync your wishlist across devices and never lose track of what you love.</p>
  <div class="wishlist-nudge__actions">
    <a href="{{ routes.account_register_url }}" class="btn btn--primary">Create Account</a>
    <a href="{{ routes.account_login_url }}" class="btn btn--secondary">Sign In</a>
  </div>
  <p class="wishlist-nudge__note">Your saved items are stored on this device for now.</p>
</div>

<style>
.wishlist-nudge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  text-align: center;
  background: var(--color-cream);
  border-radius: var(--radius-xl);
  padding: var(--space-8) var(--space-6);
  max-width: 400px;
  margin: 0 auto var(--space-8);
}

.wishlist-nudge__icon {
  width: 64px;
  height: 64px;
  background: rgba(128,0,32,0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-burgundy);
}

.wishlist-nudge__title {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 400;
  color: var(--color-text-dark);
}

.wishlist-nudge__text {
  font-size: var(--text-sm);
  color: var(--color-text-mid);
  line-height: 1.7;
}

.wishlist-nudge__actions {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
  justify-content: center;
}

.wishlist-nudge__note {
  font-size: var(--text-xs);
  color: var(--color-text-light);
}
</style>
