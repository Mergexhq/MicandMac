{%- comment -%}
  Accepts:
  - collection: {Object} Collection Liquid object
  - custom_image: {Object} Image object to override collection image (optional)
  - custom_title: {String} Title to override collection title (optional)

  Usage:
  {% render 'collection-card', collection: collection %}
{%- endcomment -%}

<a href="{{ collection.url }}" class="collection-card group block relative aspect-[4/5] bg-gray-100 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
  {%- assign current_image = custom_image | default: collection.featured_image -%}
  
  {%- if current_image != blank -%}
    <img
      src="{{ current_image | image_url: width: 800 }}"
      alt="{{ current_image.alt | default: collection.title | escape }}"
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      width="800"
      height="{{ 800 | divided_by: current_image.aspect_ratio | round }}"
      loading="lazy"
    >
  {%- else -%}
    <div class="w-full h-full bg-gray-100"></div>
  {%- endif -%}

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300"></div>

  <!-- Content -->
  <div class="absolute inset-x-0 bottom-0 p-6 flex flex-col items-center justify-end text-white text-center h-full">
    <h3 class="text-2xl md:text-3xl font-light tracking-wide mb-2" style="font-family: var(--font-display);">
      {{ custom_title | default: collection.title | escape }}
    </h3>
    
    <span class="inline-block border-b border-white pb-1 text-sm font-medium uppercase tracking-widest opacity-0 translate-y-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
      Shop Now
    </span>
  </div>
</a>
