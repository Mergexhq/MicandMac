{% comment %}
  Snippet: sticky-atc
  Usage: {% render 'sticky-atc', product: product %}
  Visible only when main ATC is not in viewport (detected by JS)
{% endcomment %}

{%- assign first_variant = product.selected_or_first_available_variant -%}

<div class="sticky-atc" id="StickyAtc" aria-hidden="true">
  <div class="container">
    <div class="sticky-atc__inner">

      <!-- Product info -->
      <div class="sticky-atc__info">
        {%- if product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 80 }}"
            alt="{{ product.title }}"
            width="48"
            height="48"
            class="sticky-atc__thumb"
            loading="lazy"
          >
        {%- endif -%}
        <div>
          <p class="sticky-atc__title">{{ product.title }}</p>
          <div class="sticky-atc__price">
            {% render 'price', variant: first_variant, show_badge: false %}
          </div>
        </div>
      </div>

      <!-- Variant (abbreviated) -->
      {%- unless product.has_only_default_variant -%}
        <select class="sticky-atc__variant-select form-select" id="StickyVariantSelect" aria-label="Select variant">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              data-price="{{ variant.price | money }}"
              {% unless variant.available %}disabled{% endunless %}
              {% if variant == first_variant %}selected{% endif %}
            >
              {{ variant.title }}{% unless variant.available %} — Sold Out{% endunless %}
            </option>
          {%- endfor -%}
        </select>
      {%- endunless -%}

      <!-- ATC -->
      {%- if first_variant.available -%}
        <button
          class="btn btn--primary sticky-atc__btn"
          id="StickyAtcBtn"
          data-atc
          data-variant-id="{{ first_variant.id }}"
        >
          Add to Cart
        </button>
      {%- else -%}
        <button class="btn btn--secondary sticky-atc__btn" disabled>Sold Out</button>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
.sticky-atc {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-nav);
  background: var(--color-white);
  border-top: 1px solid var(--color-beige);
  box-shadow: 0 -4px 24px rgba(128,0,32,0.1);
  transform: translateY(100%);
  transition: transform var(--transition-base);
}

.sticky-atc.is-visible {
  transform: translateY(0);
}

.sticky-atc__inner {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding-block: var(--space-3);
}

.sticky-atc__info {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex: 1;
  min-width: 0;
}

.sticky-atc__thumb {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  object-fit: cover;
  flex-shrink: 0;
  background: var(--color-beige);
}

.sticky-atc__title {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-dark);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sticky-atc__price .price__current {
  font-size: var(--text-sm);
}

.sticky-atc__variant-select {
  max-width: 180px;
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  flex-shrink: 0;
}

.sticky-atc__btn {
  flex-shrink: 0;
}

@media (max-width: 639px) {
  .sticky-atc__info { display: none; }
  .sticky-atc__btn  { width: 100%; }
}
</style>
