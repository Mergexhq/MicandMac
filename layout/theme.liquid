<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#4B2A31">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  {%- if page_image -%}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  {%- endif -%}

  {{ content_for_header }}

  <!-- Google Fonts: Great Vibes (script) + Cormorant Garamond (display) + DM Sans (body) -->
  {% comment %}theme-check-disable{% endcomment %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  {% comment %}theme-check-enable{% endcomment %}

  <!-- Modular CSS — load order matters (tokens → reset → … → animations) -->
  {{ 'tokens.css'     | asset_url | stylesheet_tag }}
  {{ 'reset.css'      | asset_url | stylesheet_tag }}
  {{ 'typography.css' | asset_url | stylesheet_tag }}
  {{ 'layout.css'     | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'header.css'     | asset_url | stylesheet_tag }}
  {{ 'mobile-nav.css' | asset_url | stylesheet_tag }}
  {{ 'animations.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css'      | asset_url | stylesheet_tag }}
  {{ 'pdp.css'        | asset_url | stylesheet_tag }}

  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <!-- RealFaviconGenerator HTML markups -->
  <link rel="icon" type="image/png" href="{{ 'favicon-96x96.png' | asset_url }}" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}" />
  <link rel="shortcut icon" href="{{ 'favicon.ico' | asset_url }}" />
  <link rel="apple-touch-icon" sizes="180x180" href="{{ 'apple-touch-icon.png' | asset_url }}" />
  <meta name="apple-mobile-web-app-title" content="Mic & Mac" />
  <link rel="manifest" href="{{ 'site.webmanifest' | asset_url }}" />
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  <!-- Skip to content (accessibility) -->
  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  <!-- Announcement Bar Section -->
  {%- section 'announcement-bar' -%}

  <!-- Header -->
  {%- section 'header' -%}

  <!-- Cart Drawer -->
  {%- section 'cart-drawer' -%}

  <!-- Main Content -->
  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {%- section 'footer' -%}

  <!-- Global JS data (read by theme modules) -->
  <script>
    window.productHandle    = {{ product.handle | json | default: 'null' }};
    window.customerLoggedIn = {% if customer %}true{% else %}false{% endif %};
    window.wishlistSyncUrl  = '';
  </script>

  <!-- Global JS -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  <!-- Mobile Navigation JS (top bar, drawer, bottom dock) -->
  <script src="{{ 'mobile-nav.js' | asset_url }}" defer></script>

  <!-- Cart JS -->
  <script src="{{ 'cart.js' | asset_url }}" defer></script>

  <!-- Cinematic Animation Engine: GSAP + Three.js + Scroll Reveals -->
  {% comment %}theme-check-disable{% endcomment %}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/three@0.162.0/build/three.min.js" defer></script>
  {% comment %}theme-check-enable{% endcomment %}
  <script src="{{ 'cinematic.js' | asset_url }}" defer></script>

  <!-- WhatsApp Sticky CTA -->
  {%- render 'whatsapp-sticky' -%}

</body>
</html>
