  {
    "name": "Social Media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "Twitter / X URL"
