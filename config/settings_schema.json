      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent color",
        "default": "#D4AF37"
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background color",
        "default": "#FFFFFF"
      }
    ]
