{% comment %}
  Block: faq-item
  Parent: sections/faq-accordion.liquid
  Usage: {% render 'faq-item', block: block %}
{% endcomment %}

<details class="faq-item" {{ block.shopify_attributes }}>
  <summary class="faq-item__q">
    {{ block.settings.question }}
    <svg class="faq-item__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </summary>
  <div class="faq-item__a rte">
    {{ block.settings.answer }}
  </div>
</details>

<style>
.faq-item {
  border-bottom: 1px solid var(--color-beige);
}

.faq-item__q {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-4);
  padding: var(--space-5) 0;
  font-size: var(--text-base);
  font-weight: 500;
  color: var(--color-text-dark);
  cursor: pointer;
  list-style: none;
  user-select: none;
}

.faq-item__q::-webkit-details-marker { display: none; }

.faq-item__icon {
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.faq-item[open] .faq-item__icon {
  transform: rotate(180deg);
}

.faq-item__a {
  padding-bottom: var(--space-5);
  font-size: var(--text-sm);
  color: var(--color-text-mid);
  line-height: 1.8;
}
</style>

{% schema %}
{
  "name": "FAQ Item",
  "settings": [
    { "type": "text", "id": "question", "label": "Question", "default": "What makes your products different?" },
    { "type": "richtext", "id": "answer", "label": "Answer" }
  ]
}
{% endschema %}
