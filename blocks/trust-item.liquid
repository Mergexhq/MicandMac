{% comment %}
  Block: trust-item
  Parent: sections with trust row
  Usage: {% render 'trust-item', block: block %}
{% endcomment %}

<div class="trust-item" {{ block.shopify_attributes }}>
  {%- if block.settings.icon_emoji != blank -%}
    <div class="trust-item__icon" aria-hidden="true">{{ block.settings.icon_emoji }}</div>
  {%- elsif block.settings.icon_image != blank -%}
    <div class="trust-item__icon">
      <img src="{{ block.settings.icon_image | image_url: width: 80 }}" alt="" width="40" height="40" loading="lazy">
    </div>
  {%- endif -%}
  <div class="trust-item__copy">
    <strong class="trust-item__heading">{{ block.settings.heading }}</strong>
    {%- if block.settings.subtext != blank -%}
      <p class="trust-item__subtext">{{ block.settings.subtext }}</p>
    {%- endif -%}
  </div>
</div>

<style>
.trust-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
}

.trust-item__icon {
  font-size: 2rem;
  width: 48px;
  height: 48px;
  background: rgba(0,80,0,0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.trust-item__heading {
  display: block;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text-dark);
  margin-bottom: var(--space-1);
}

.trust-item__subtext {
  font-size: var(--text-xs);
  color: var(--color-text-mid);
  line-height: 1.5;
}
</style>
