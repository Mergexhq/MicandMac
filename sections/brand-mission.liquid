{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .brand-mission-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media screen and (min-width: 768px) {
    .brand-mission-section {
      grid-template-columns: 1fr 1fr;
    }
  }

  .brand-mission-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted, #999);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .brand-mission-content {
    max-width: 480px;
  }

  .brand-mission-text {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 300;
    color: var(--color-text-primary, #1a1a1a);
    line-height: 1.4;
    margin-bottom: 2rem;
  }

  .brand-mission-text::first-letter {
    font-family: var(--font-script);
    font-size: 2em;
    font-weight: 400;
    line-height: 0.7;
    float: left;
    margin-right: 0.06em;
    margin-top: 0.04em;
  }

  .brand-mission-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 1px solid #e5e7eb;
    border-radius: 100px;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 0.875rem;
    transition: background-color 0.2s;
  }

  .brand-mission-btn:hover {
    background-color: #f9fafb;
  }
{%- endstyle -%}

<div class="brand-mission-section section-{{ section.id }}-padding">
  <div class="brand-mission-label">
    {{ section.settings.label }}
  </div>
  <div class="brand-mission-content">
    <div class="brand-mission-text">
      {{ section.settings.text }}
    </div>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="brand-mission-btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Brand Mission",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "Brand Mission"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description Text",
      "default": "The brand's goal is to give a feeling of luxury spa care without being over the top. We want to focus on the skincare experience and packaging should not be distracting."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Brand Mission"
    }
  ]
}
{% endschema %}
