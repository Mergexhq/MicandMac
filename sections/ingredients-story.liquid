{% comment %}
  Section: Ingredients Story
  - Feature key clean ingredients with brand storytelling
  - Two-column layout: image + content
{% endcomment %}

<section class="ingredients-story section-{{ section.id }}-padding">
  <div class="container">
    <div class="ingredients-story__inner">
      <!-- Image Side -->
      <div class="ingredients-story__media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            srcset="
              {{ section.settings.image | image_url: width: 400 }} 400w,
              {{ section.settings.image | image_url: width: 800 }} 800w
            "
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
            width="800"
            height="900"
            class="ingredients-story__img"
          >
        {%- else -%}
          <div class="ingredients-story__placeholder">
            <div class="placeholder-leaf">🌿</div>
          </div>
        {%- endif -%}
        {%- if section.settings.badge_text != blank -%}
          <div class="ingredients-story__badge">{{ section.settings.badge_text }}</div>
        {%- endif -%}
      </div>

      <!-- Content Side -->
      <div class="ingredients-story__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="ingredients-story__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <p class="ingredients-story__subtext">{{ section.settings.subtext }}</p>
        {%- endif -%}

        <!-- Ingredient Pills -->
        <div class="ingredients-story__pills">
          {%- for i in (1..4) -%}
            {%- assign label_key = 'ingredient_' | append: i | append: '_label' -%}
            {%- assign desc_key  = 'ingredient_' | append: i | append: '_desc' -%}
            {%- if section.settings[label_key] != blank -%}
              <div class="ingredient-pill">
                <span class="ingredient-pill__dot"></span>
                <div>
                  <strong>{{ section.settings[label_key] }}</strong>
                  {%- if section.settings[desc_key] != blank -%}
                    <p>{{ section.settings[desc_key] }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link }}" class="btn btn--primary">
            {{ section.settings.cta_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
.ingredients-story {
  padding-block: var(--space-20, 5rem);
}

.ingredients-story__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16, 4rem);
  align-items: center;
}

.ingredients-story__media {
  position: relative;
  border-radius: var(--radius, 12px);
  overflow: hidden;
}

.ingredients-story__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--radius, 12px);
  display: block;
}

.ingredients-story__placeholder {
  background: linear-gradient(135deg, var(--color-primary, #2D4A3E) 0%, var(--color-highlight, #A8C5BA) 100%);
  min-height: 480px;
  border-radius: var(--radius, 12px);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-leaf {
  font-size: 5rem;
  opacity: 0.4;
}

.ingredients-story__badge {
  position: absolute;
  bottom: 1.5rem;
  left: 1.5rem;
  background: var(--color-accent, #C8A96E);
  color: var(--color-primary, #2D4A3E);
  font-weight: 700;
  font-size: 0.8rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 0.5rem 1rem;
  border-radius: var(--radius-pill, 999px);
}

.eyebrow {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--color-accent, #C8A96E);
  font-weight: 700;
  margin-bottom: 0.75rem;
}

.ingredients-story__heading {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 300;
  margin-bottom: 1rem;
  line-height: 1.2;
}

.ingredients-story__subtext {
  color: var(--color-text, #1C2B25);
  opacity: 0.75;
  line-height: 1.7;
  margin-bottom: 2rem;
}

.ingredients-story__pills {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2.5rem;
}

.ingredient-pill {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.ingredient-pill__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--color-accent, #C8A96E);
  flex-shrink: 0;
  margin-top: 0.35rem;
}

.ingredient-pill strong {
  font-family: var(--font-heading, 'Playfair Display', serif);
  font-size: 1rem;
  display: block;
  color: var(--color-primary, #2D4A3E);
}

.ingredient-pill p {
  font-size: 0.875rem;
  opacity: 0.7;
  margin: 0.25rem 0 0;
  line-height: 1.5;
}

@media (max-width: 767px) {
  .ingredients-story__inner { grid-template-columns: 1fr; }
  .ingredients-story__media { order: -1; }
}
</style>

{% schema %}
{
  "name": "Ingredients Story",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Feature image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Image badge text",
      "default": "100% Natural"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "What's Inside Matters"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Ingredients You Can Trust"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every formula starts with ingredients sourced for purity and potency. No fillers. No compromise."
    },
    {
      "type": "header",
      "content": "Ingredient 1"
    },
    { "type": "text", "id": "ingredient_1_label", "label": "Name", "default": "Rosehip Oil" },
    { "type": "text", "id": "ingredient_1_desc",  "label": "Description", "default": "Rich in Vitamin C — brightens and evens skin tone." },
    {
      "type": "header",
      "content": "Ingredient 2"
    },
    { "type": "text", "id": "ingredient_2_label", "label": "Name", "default": "Turmeric Extract" },
    { "type": "text", "id": "ingredient_2_desc",  "label": "Description", "default": "Anti-inflammatory — reduces redness and blemishes." },
    {
      "type": "header",
      "content": "Ingredient 3"
    },
    { "type": "text", "id": "ingredient_3_label", "label": "Name", "default": "Aloe Vera" },
    { "type": "text", "id": "ingredient_3_desc",  "label": "Description", "default": "Deeply hydrating — soothes and calms sensitive skin." },
    {
      "type": "header",
      "content": "Ingredient 4"
    },
    { "type": "text", "id": "ingredient_4_label", "label": "Name", "default": "Sandalwood" },
    { "type": "text", "id": "ingredient_4_desc",  "label": "Description", "default": "Balances oil production — a timeless Indian beauty secret." },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Explore All Ingredients"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Ingredients Story",
      "category": "Content"
    }
  ]
}
{% endschema %}
