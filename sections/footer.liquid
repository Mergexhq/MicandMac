{% comment %}
  Section: Footer
  - Brand column + 3 link columns + newsletter + social + payment icons
  - Each link column managed via footer-column blocks
{% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="container">

    <!-- Top: Brand + Columns + Newsletter -->
    <div class="footer__top">

      <!-- Brand Column -->
      <div class="footer__brand">
        {%- if section.settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="footer__logo">
            <img
              src="{{ section.settings.logo | image_url: width: 160 }}"
              alt="{{ shop.name }}"
              width="120"
              height="40"
              loading="lazy"
            >
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer__logo-text">{{ shop.name }}</a>
        {%- endif -%}

        {%- if section.settings.brand_desc != blank -%}
          <p class="footer__brand-desc">{{ section.settings.brand_desc }}</p>
        {%- endif -%}

        <!-- Social Icons -->
        <div class="footer__social">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener" class="footer__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" aria-label="Facebook" target="_blank" rel="noopener" class="footer__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.youtube != blank -%}
            <a href="{{ section.settings.youtube }}" aria-label="YouTube" target="_blank" rel="noopener" class="footer__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.whatsapp != blank -%}
            <a href="https://wa.me/{{ section.settings.whatsapp }}" aria-label="WhatsApp" target="_blank" rel="noopener" class="footer__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Link Columns (from blocks) -->
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_column' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              <h4 class="footer__col-title">{{ block.settings.heading }}</h4>
              <ul class="footer__col-links">
                {%- for i in (1..5) -%}
                  {%- liquid
                    assign label_key = 'link_' | append: i | append: '_label'
                    assign url_key   = 'link_' | append: i | append: '_url'
                    assign label = block.settings[label_key]
                    assign url   = block.settings[url_key]
                  -%}
                  {%- if label != blank and url != blank -%}
                    <li><a href="{{ url }}" class="footer__col-link">{{ label }}</a></li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <!-- Default columns when no blocks set -->
        <div class="footer__col">
          <h4 class="footer__col-title">Shop</h4>
          <ul class="footer__col-links">
            <li><a href="{{ routes.all_products_collection_url }}" class="footer__col-link">All Products</a></li>
            <li><a href="{{ routes.collections_url }}/bestsellers" class="footer__col-link">Bestsellers</a></li>
            <li><a href="{{ routes.collections_url }}/new-arrivals" class="footer__col-link">New Arrivals</a></li>
            <li><a href="{{ routes.collections_url }}/combos" class="footer__col-link">Combos</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h4 class="footer__col-title">Company</h4>
          <ul class="footer__col-links">
            <li><a href="/pages/about" class="footer__col-link">About Us</a></li>
            <li><a href="/blogs/news" class="footer__col-link">Journal</a></li>
            <li><a href="/pages/contact" class="footer__col-link">Contact</a></li>
          </ul>
        </div>
        <div class="footer__col">
          <h4 class="footer__col-title">Help</h4>
          <ul class="footer__col-links">
            <li><a href="/policies/shipping-policy" class="footer__col-link">Shipping Policy</a></li>
            <li><a href="/policies/refund-policy" class="footer__col-link">Returns & Refunds</a></li>
            <li><a href="/policies/privacy-policy" class="footer__col-link">Privacy Policy</a></li>
            <li><a href="/pages/faq" class="footer__col-link">FAQ</a></li>
          </ul>
        </div>
      {%- endif -%}

      <!-- Newsletter -->
      {%- if section.settings.show_newsletter -%}
        <div class="footer__newsletter">
          <h4 class="footer__col-title">{{ section.settings.newsletter_heading | default: 'Stay in the loop' }}</h4>
          <p class="footer__newsletter-sub">{{ section.settings.newsletter_sub | default: 'Get skincare tips & exclusive offers.' }}</p>
          {%- form 'customer', class: 'footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="footer__newsletter-row">
              <input
                type="email"
                name="contact[email]"
                class="footer__newsletter-input"
                placeholder="your@email.com"
                autocomplete="email"
                aria-label="Email address"
                required
              >
              <button type="submit" class="btn btn--primary btn--sm">Subscribe</button>
            </div>
            {%- if form.errors -%}
              <p class="footer__newsletter-error">{{ form.errors | default_errors }}</p>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <p class="footer__newsletter-success">You're subscribed! 🎉</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div><!-- /.footer__top -->

    <!-- Bottom: copyright + payment -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. &nbsp;·&nbsp; Made in India 🇮🇳
      </p>

      <div class="footer__policy-links">
        <a href="{{ shop.privacy_policy.url }}">Privacy</a>
        <a href="{{ shop.refund_policy.url }}">Returns</a>
        <a href="{{ shop.shipping_policy.url }}">Shipping</a>
        <a href="{{ shop.terms_of_service.url }}">Terms</a>
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</footer>

<style>
.site-footer {
  background: var(--color-text-dark);
  color: rgba(255,255,255,0.75);
  padding-top: var(--space-16);
  padding-bottom: var(--space-8);
  margin-top: var(--space-20);
}

.footer__top {
  display: grid;
  grid-template-columns: 1.4fr repeat(3, 1fr);
  gap: var(--space-10);
  padding-bottom: var(--space-12);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.footer__logo-text {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 300;
  color: var(--color-white);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  display: block;
  margin-bottom: var(--space-4);
}

.footer__brand-desc {
  font-size: var(--text-sm);
  line-height: 1.7;
  color: rgba(255,255,255,0.55);
  max-width: 240px;
  margin-bottom: var(--space-5);
}

.footer__social {
  display: flex;
  gap: var(--space-3);
}

.footer__social-link {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 50%;
  color: rgba(255,255,255,0.6);
  transition: all var(--transition-base);
}

.footer__social-link:hover {
  border-color: var(--color-gold);
  color: var(--color-gold);
}

.footer__col-title {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-white);
  margin-bottom: var(--space-5);
}

.footer__col-links {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer__col-link {
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.55);
  transition: color var(--transition-fast);
}

.footer__col-link:hover {
  color: var(--color-gold);
}

/* Newsletter */
.footer__newsletter-sub {
  font-size: var(--text-sm);
  color: rgba(255,255,255,0.55);
  margin-bottom: var(--space-4);
  line-height: 1.6;
}

.footer__newsletter-row {
  display: flex;
  gap: var(--space-2);
}

.footer__newsletter-input {
  flex: 1;
  padding: 0.625rem 1rem;
  background: rgba(255,255,255,0.08);
  border: 1.5px solid rgba(255,255,255,0.15);
  border-radius: var(--radius-pill);
  font-size: var(--text-sm);
  color: var(--color-white);
  outline: none;
  transition: border-color var(--transition-fast);
}

.footer__newsletter-input::placeholder {
  color: rgba(255,255,255,0.3);
}

.footer__newsletter-input:focus {
  border-color: var(--color-gold);
}

.footer__newsletter-error { color: #ff8080; font-size: var(--text-xs); margin-top: var(--space-2); }
.footer__newsletter-success { color: #7ed8a4; font-size: var(--text-xs); margin-top: var(--space-2); }

/* Bottom bar */
.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-4);
  padding-top: var(--space-6);
}

.footer__copyright {
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.35);
  line-height: 1;
}

.footer__policy-links {
  display: flex;
  gap: var(--space-4);
}

.footer__policy-links a {
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.35);
  transition: color var(--transition-fast);
}

.footer__policy-links a:hover {
  color: var(--color-gold);
}

.footer__payment {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  opacity: 0.5;
}

.footer__payment-icon {
  height: 20px;
  width: auto;
}

/* Responsive */
@media (max-width: 1023px) {
  .footer__top {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }
}

@media (max-width: 639px) {
  .footer__top {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  .footer__bottom {
    flex-direction: column;
    text-align: center;
  }
}
</style>

{% schema %}
{
  "name": "Footer",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo (optional)"
    },
    {
      "type": "textarea",
      "id": "brand_desc",
      "label": "Brand description",
      "default": "Wine & wellness rituals for your daily glow. Handcrafted with Donkey Milk, Red Wine & Aloe Vera."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube URL"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number (country code, no +)",
      "placeholder": "919876543210"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_sub",
      "label": "Newsletter subtext",
      "default": "Get skincare tips & exclusive offers."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading"
        },
        {
          "type": "text",
          "id": "link_1_label",
          "label": "Link 1 label"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_label",
          "label": "Link 2 label"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_label",
          "label": "Link 3 label"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_label",
          "label": "Link 4 label"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        },
        {
          "type": "text",
          "id": "link_5_label",
          "label": "Link 5 label"
        },
        {
          "type": "url",
          "id": "link_5_url",
          "label": "Link 5 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
