{% comment %}
  Redirects the /collections (list collections) page to /collections/all
  as per user request "dont show this page".
{% endcomment %}

<script>
  window.location.replace("{{ routes.all_products_collection_url }}");
</script>

<div class="container container--narrow text-center" style="padding: 15vh 20px;">
  <p style="font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; opacity: 0.6;">Redirecting to the collection...</p>
  <noscript>
    <meta http-equiv="refresh" content="0;url={{ routes.all_products_collection_url }}">
    <p>If you are not redirected, <a href="{{ routes.all_products_collection_url }}">click here</a>.</p>
  </noscript>
</div>

{% schema %}
{
  "name": "List Collections Redirect",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
