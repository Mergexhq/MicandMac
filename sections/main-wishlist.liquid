{% comment %}
  Section: Main Wishlist Page
  Inside account layout with sidebar nav.
  Grid is populated by theme.js from localStorage.
  JS targets: #WishlistGrid (container), #WishlistEmpty (empty state)
{% endcomment %}

<div class="account-page">
  <div class="container">
    <div class="account-page__layout">

      <!-- ── Sidebar ── -->
      <aside class="account-page__sidebar">
        {% render 'account-nav', current: 'wishlist' %}
      </aside>

      <!-- ── Main ── -->
      <main class="account-page__main">

        <div class="acct-header">
          <h1 class="acct-header__title">Saved for later</h1>
          <p class="acct-header__subtitle">Products you've set aside</p>
        </div>

        <!-- Outer container — JS will inject product-card.wishlist-card elements here -->
        <div class="wishlist-grid__inner" id="WishlistGrid">

          <!-- Empty state — shown/hidden by wishlist.ts -->
          <div class="acct-empty" id="WishlistEmpty" style="display:none">
            <div class="acct-empty__icon">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
              </svg>
            </div>
            <h2 class="acct-empty__title">Nothing saved yet</h2>
            <p class="acct-empty__text">Tap the heart on any product to save it here.</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn--outline">Browse products</a>
          </div>

        </div>

        <style>
          /* Override wishlist grid inside account layout */
          #WishlistGrid.wishlist-grid__inner {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1.5rem;
          }
          #WishlistGrid .wishlist-card {
            border-radius: 14px;
            overflow: hidden;
          }
          #WishlistEmpty {
            grid-column: 1 / -1;
            text-align: center;
            padding: 3rem 0;
          }
        </style>

      </main>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Wishlist",
  "settings": []
}
{% endschema %}
