{% comment %}
  Section: Collection Tiles
  4 clickable category image cards with hover zoom + title overlay
{% endcomment %}

<section class="collection-tiles section-padding">
  <div class="container">

    {%- if section.settings.heading != blank -%}
      <div class="section-heading">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="collection-tiles__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tile' -%}
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="collection-tile"
            {{ block.shopify_attributes }}
          >
            <div class="collection-tile__media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  srcset="
                    {{ block.settings.image | image_url: width: 400 }} 400w,
                    {{ block.settings.image | image_url: width: 800 }} 800w
                  "
                  sizes="(max-width: 639px) 50vw, 25vw"
                  alt="{{ block.settings.label | escape }}"
                  width="800"
                  height="1000"
                  loading="lazy"
                >
              {%- else -%}
                <div class="collection-tile__placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>
            <div class="collection-tile__overlay">
              <span class="collection-tile__label">{{ block.settings.label }}</span>
              <span class="collection-tile__cta">Shop Now →</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
.collection-tiles__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-4);
}

.collection-tile {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: block;
  aspect-ratio: 4/5;
}

.collection-tile__media {
  width: 100%;
  height: 100%;
  position: absolute;
  inset: 0;
}

.collection-tile__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-slow);
}

.collection-tile:hover .collection-tile__media img {
  transform: scale(1.06);
}

.collection-tile__placeholder {
  width: 100%;
  height: 100%;
  background: var(--color-beige);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-light);
}

.collection-tile__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(26,0,8,0.7) 0%, rgba(26,0,8,0.15) 50%, transparent 100%);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  padding: var(--space-5) var(--space-6);
  transition: all var(--transition-base);
}

.collection-tile__label {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 400;
  color: var(--color-white);
  line-height: 1.2;
  display: block;
  margin-bottom: var(--space-2);
}

.collection-tile__cta {
  font-size: var(--text-xs);
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-gold);
  opacity: 0;
  transform: translateY(8px);
  transition: all var(--transition-base);
}

.collection-tile:hover .collection-tile__cta {
  opacity: 1;
  transform: translateY(0);
}

@media (max-width: 767px) {
  .collection-tiles__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
</style>

{% schema %}
{
  "name": "Collection tiles",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collection tile",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category label",
          "default": "Face Care"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection tiles",
      "blocks": [
        { "type": "tile", "settings": { "label": "Face Care" } },
        { "type": "tile", "settings": { "label": "Body Care" } },
        { "type": "tile", "settings": { "label": "Hair Care" } },
        { "type": "tile", "settings": { "label": "Combos" } }
      ]
    }
  ]
}
{% endschema %}
