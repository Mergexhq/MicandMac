{% comment %}Section: Main Order Detail{% endcomment %}

<div class="account-page section-padding">
  <div class="container">
    <div class="account-page__layout">
      <aside class="account-page__sidebar">
        {% render 'account-nav', current: 'orders' %}
      </aside>
      <main class="account-page__main">
        <a href="{{ routes.account_url }}" class="account-back">← Back to account</a>
        <h1 class="account-page__title">Order #{{ order.name }}</h1>
        <p class="order-date">Placed {{ order.created_at | date: '%B %d, %Y' }}</p>

        {% render 'order-timeline', order: order %}

        <!-- Line items -->
        <section class="account-section">
          <h2 class="account-section__heading">Items</h2>
          {%- for item in order.line_items -%}
            <div class="order-item">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}" width="80" height="80" loading="lazy" class="order-item__img">
              {%- endif -%}
              <div class="order-item__info">
                <p class="order-item__title">{{ item.product.title }}</p>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p class="order-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="order-item__qty">Qty: {{ item.quantity }}</p>
              </div>
              <p class="order-item__price">{{ item.final_line_price | money }}</p>
            </div>
          {%- endfor -%}
        </section>

        <!-- Totals -->
        <section class="account-section order-totals">
          <div class="order-totals__row"><span>Subtotal</span><span>{{ order.subtotal_price | money }}</span></div>
          {%- for discount in order.cart_level_discount_applications -%}
            <div class="order-totals__row order-totals__row--discount"><span>{{ discount.title }}</span><span>-{{ discount.total_allocated_amount | money }}</span></div>
          {%- endfor -%}
          <div class="order-totals__row"><span>Shipping</span><span>{{ order.shipping_price | money }}</span></div>
          <div class="order-totals__row"><span>Tax</span><span>{{ order.tax_price | money }}</span></div>
          <div class="order-totals__total"><span>Total</span><span>{{ order.total_price | money }}</span></div>
        </section>

        <!-- Shipping address -->
        {%- if order.shipping_address -%}
          <section class="account-section">
            <h2 class="account-section__heading">Shipping Address</h2>
            <address class="account-address">{{ order.shipping_address | format_address }}</address>
          </section>
        {%- endif -%}
      </main>
    </div>
  </div>
</div>

<style>
.account-back { color: var(--color-text-light); font-size: var(--text-sm); display: inline-flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-5); text-decoration: none; }
.account-back:hover { color: var(--color-forest); }
.order-date { font-size: var(--text-sm); color: var(--color-text-light); margin-bottom: var(--space-4); }

.order-item { display: grid; grid-template-columns: 80px 1fr auto; gap: var(--space-4); padding-block: var(--space-4); border-bottom: 1px solid var(--color-beige); align-items: start; }
.order-item__img { width: 80px; height: 80px; border-radius: var(--radius-md); object-fit: cover; background: var(--color-beige); }
.order-item__title { font-weight: 500; font-size: var(--text-sm); color: var(--color-text-dark); }
.order-item__variant, .order-item__qty { font-size: var(--text-xs); color: var(--color-text-light); }
.order-item__price { font-weight: 500; font-size: var(--text-sm); text-align: right; }

.order-totals { max-width: 340px; }
.order-totals__row { display: flex; justify-content: space-between; padding-block: var(--space-2); font-size: var(--text-sm); color: var(--color-text-mid); }
.order-totals__row--discount { color: var(--color-forest); }
.order-totals__total { display: flex; justify-content: space-between; padding-top: var(--space-4); font-weight: 600; font-size: var(--text-lg); color: var(--color-text-dark); border-top: 1px solid var(--color-beige); }
</style>
