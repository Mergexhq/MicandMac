{% comment %}
  Section: Promo Banner
  Full-width band with headline, subtext, optional countdown + CTA
{% endcomment %}

{%- liquid
  assign has_bg_image = false
  if section.settings.bg_image != blank
    assign has_bg_image = true
  endif
-%}

<section
  class="promo-banner"
  style="
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    {% if has_bg_image %}position: relative; overflow: hidden;{% endif %}
  "
>
  {%- if has_bg_image -%}
    <div class="promo-banner__bg">
      <img
        src="{{ section.settings.bg_image | image_url: width: 1440 }}"
        alt=""
        width="1440"
        height="500"
        loading="lazy"
        aria-hidden="true"
      >
    </div>
    <div class="promo-banner__bg-overlay" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity }})"></div>
  {%- endif -%}

  <div class="container promo-banner__inner">
    <div class="promo-banner__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow" style="color: {{ section.settings.eyebrow_color | default: section.settings.text_color }}">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}

      <h2 class="promo-banner__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.subtext != blank -%}
        <p class="promo-banner__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if section.settings.show_countdown and section.settings.countdown_end != blank -%}
        <div class="promo-banner__countdown" id="PromoCountdown-{{ section.id }}" data-end="{{ section.settings.countdown_end }}">
          <div class="countdown-unit"><span class="countdown-num" data-unit="days">00</span><span class="countdown-label">Days</span></div>
          <span class="countdown-sep">:</span>
          <div class="countdown-unit"><span class="countdown-num" data-unit="hours">00</span><span class="countdown-label">Hours</span></div>
          <span class="countdown-sep">:</span>
          <div class="countdown-unit"><span class="countdown-num" data-unit="minutes">00</span><span class="countdown-label">Mins</span></div>
          <span class="countdown-sep">:</span>
          <div class="countdown-unit"><span class="countdown-num" data-unit="seconds">00</span><span class="countdown-label">Secs</span></div>
        </div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="btn {% if has_bg_image %}btn--ghost{% else %}btn--secondary{% endif %} btn--lg"
          style="
            {% unless has_bg_image %}
              color: {{ section.settings.text_color }};
              border-color: {{ section.settings.text_color }};
            {% endunless %}
          "
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
.promo-banner {
  padding-block: var(--space-16);
  text-align: center;
}

.promo-banner__bg {
  position: absolute;
  inset: 0;
}

.promo-banner__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.promo-banner__bg-overlay {
  position: absolute;
  inset: 0;
}

.promo-banner__inner {
  position: relative;
  z-index: 1;
}

.promo-banner__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-5);
}

.promo-banner__heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 300;
  line-height: 1.15;
  max-width: 700px;
}

.promo-banner__subtext {
  font-size: var(--text-lg);
  opacity: 0.85;
  max-width: 500px;
  line-height: 1.6;
}

/* Countdown */
.promo-banner__countdown {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  justify-content: center;
}

.countdown-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 64px;
  background: rgba(255,255,255,0.12);
  border-radius: var(--radius-md);
  padding: var(--space-3) var(--space-4);
}

.countdown-num {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 400;
  line-height: 1;
}

.countdown-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  opacity: 0.7;
  margin-top: 2px;
}

.countdown-sep {
  font-size: var(--text-2xl);
  font-weight: 300;
  opacity: 0.6;
  margin-bottom: var(--space-4);
}

@media (max-width: 639px) {
  .promo-banner { padding-block: var(--space-12); }
  .countdown-unit { min-width: 52px; padding: var(--space-2) var(--space-3); }
  .countdown-num { font-size: var(--text-2xl); }
}
</style>

{% schema %}
{
  "name": "Promo banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Limited Time"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow colour"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Buy 2 Get ₹50 OFF on All Combos"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Stock up on your favourites and save big."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop the Offer"
    },
    {
      "type": "header",
      "content": "Design"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#800020"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & button colour",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (optional)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 0.9,
      "step": 0.1,
      "default": 0.4
    },
    {
      "type": "header",
      "content": "Countdown timer"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show countdown timer",
      "default": false
    },
    {
      "type": "text",
      "id": "countdown_end",
      "label": "End date/time (ISO 8601)",
      "placeholder": "2026-12-31T23:59:59"
    }
  ],
  "presets": [
    {
      "name": "Promo banner"
    }
  ]
}
{% endschema %}
