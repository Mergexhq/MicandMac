{% comment %}
  Section: CTA Banner
  Reusable full-width call-to-action closer for any page
{% endcomment %}

<section
  class="cta-banner"
  {%- if section.settings.bg_image != blank -%}
    style="--cta-overlay: {{ section.settings.overlay_opacity | default: 0.5 }}"
  {%- else -%}
    style="background: {{ section.settings.bg_color | default: '#800020' }};"
  {%- endif -%}
>
  {%- if section.settings.bg_image != blank -%}
    <div class="cta-banner__bg">
      <img
        src="{{ section.settings.bg_image | image_url: width: 1440 }}"
        alt=""
        width="1440"
        height="400"
        loading="lazy"
        aria-hidden="true"
      >
    </div>
    <div class="cta-banner__overlay"></div>
  {%- endif -%}

  <div class="container cta-banner__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow" style="color: var(--color-gold)">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h2 class="cta-banner__heading">{{ section.settings.heading | default: 'Ready to Glow?' }}</h2>

    {%- if section.settings.subtext != blank -%}
      <p class="cta-banner__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_url | default: '/collections/all' }}"
        class="btn btn--gold btn--lg"
      >
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</section>

<style>
.cta-banner {
  position: relative;
  padding-block: var(--space-20);
  overflow: hidden;
  text-align: center;
  color: var(--color-white);
}

.cta-banner__bg {
  position: absolute;
  inset: 0;
}

.cta-banner__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cta-banner__overlay {
  position: absolute;
  inset: 0;
  background: rgba(26, 0, 8, var(--cta-overlay, 0.5));
}

.cta-banner__inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-5);
}

.cta-banner__heading {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 300;
  color: var(--color-white);
  line-height: 1.15;
  max-width: 700px;
}

.cta-banner__subtext {
  font-size: var(--text-lg);
  color: rgba(255,255,255,0.8);
  max-width: 480px;
  line-height: 1.7;
}

@media (max-width: 639px) {
  .cta-banner { padding-block: var(--space-12); }
}
</style>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your daily glow ritual starts here."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#800020"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (overrides colour)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay darkness",
      "min": 0.1,
      "max": 0.9,
      "step": 0.1,
      "default": 0.5
    }
  ],
  "presets": [
    {
      "name": "CTA banner"
    }
  ]
}
{% endschema %}
