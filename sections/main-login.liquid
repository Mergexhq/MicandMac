{% comment %}Section: Main Login{% endcomment %}

<div class="account-auth section-padding">
  <div class="container container--xs">
    <h1 class="account-auth__title">Sign In</h1>

    {%- if form.errors -%}
      <div class="form-error" role="alert">{{ form.errors | default_errors }}</div>
    {%- endif -%}

    {%- form 'customer_login', id: 'LoginForm' -%}
      <div class="form-group">
        <label for="LoginEmail" class="form-label">Email</label>
        <input type="email" id="LoginEmail" name="customer[email]" autocomplete="email" class="form-input" required autofocus>
      </div>
      <div class="form-group">
        <label for="LoginPassword" class="form-label">Password</label>
        <input type="password" id="LoginPassword" name="customer[password]" autocomplete="current-password" class="form-input" required>
        <a href="{{ routes.account_recover_url }}" class="account-auth__forgot">Forgot password?</a>
      </div>
      <button type="submit" class="btn btn--primary btn--full btn--lg">Sign In</button>
    {%- endform -%}

    <div class="account-auth__alt">
      <span>Don't have an account?</span>
      <a href="{{ routes.account_register_url }}">Create one</a>
    </div>
  </div>
</div>

<style>
.account-auth { max-width: 440px; margin-inline: auto; }
.account-auth__title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 2.75rem);
  font-weight: 300;
  text-align: center;
  margin-bottom: var(--space-8);
}
.form-group { margin-bottom: var(--space-5); }
.form-label { display: block; font-size: var(--text-sm); font-weight: 500; color: var(--color-text-dark); margin-bottom: var(--space-2); }
.account-auth__forgot { display: block; text-align: right; font-size: var(--text-xs); color: var(--color-text-light); margin-top: var(--space-2); }
.account-auth__forgot:hover { color: var(--color-forest); }
.account-auth__alt { text-align: center; margin-top: var(--space-5); font-size: var(--text-sm); color: var(--color-text-mid); display: flex; gap: var(--space-2); justify-content: center; }
.form-error { background: #fff1f0; border: 1px solid #ffb3b3; color: var(--color-burgundy); border-radius: var(--radius-md); padding: var(--space-4); margin-bottom: var(--space-5); font-size: var(--text-sm); }
</style>
