{% comment %}
  Section: About Page - Premium Narrative System
{% endcomment %}

<div class="about-page">

  <!-- 1. HERO -->
  <section class="about-hero">
    <div class="about-hero__bg">
      {%- if section.settings.hero_image != blank -%}
        <img src="{{ section.settings.hero_image | image_url: width: 1440 }}" alt="Everyday Skincare" width="1440" height="700" loading="eager" aria-hidden="true" class="about-hero__img">
      {%- else -%}
        <div class="about-hero__placeholder" style="background: var(--color-bg-cream, #F5ECD7);"></div>
      {%- endif -%}
    </div>
    <div class="container">
      <div class="about-hero__content">
        <h1 class="about-hero__title">{{ section.settings.hero_title }}</h1>
        <p class="about-hero__subtext">{{ section.settings.hero_subtext }}</p>
      </div>
    </div>
  </section>

  <!-- 2. BRAND INTENT -->
  <section class="about-intent section-padding">
    <div class="container container--narrow">
      <div class="about-intent__content">
        <p class="about-intent__text">{{ section.settings.intent_text | newline_to_br }}</p>
      </div>
    </div>
  </section>

  <!-- 3. THE PROBLEM -->
  <section class="about-problem section-padding">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__content">
          <div class="about-problem__text-block">
            <h2 class="about-section-title">{{ section.settings.problem_title }}</h2>
            <div class="about-section-text">{{ section.settings.problem_text }}</div>
          </div>
        </div>
        <div class="split-layout__media">
          {%- if section.settings.problem_image != blank -%}
            <img src="{{ section.settings.problem_image | image_url: width: 800 }}" alt="" width="800" height="800" loading="lazy" class="about-media-img">
          {%- else -%}
            <div class="about-media-placeholder" style="background: var(--color-bg-cream, #F5ECD7);"></div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <!-- 4. THE APPROACH -->
  <section class="about-approach section-padding">
    <div class="container">
      <div class="approach-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pillar' -%}
            <div class="approach-card" {{ block.shopify_attributes }}>
              <h3 class="approach-card__title">{{ block.settings.title }}</h3>
              <p class="approach-card__text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- 5. INGREDIENT PHILOSOPHY -->
  <section class="about-philosophy section-padding">
    <div class="container">
      <div class="split-layout split-layout--reverse">
        <div class="split-layout__content">
          <div class="about-philosophy__text-block">
            <h2 class="about-section-title">{{ section.settings.philosophy_title }}</h2>
            <div class="about-section-text">{{ section.settings.philosophy_text }}</div>
            <a href="/pages/ingredients" class="about-link">Discover our ingredients &rarr;</a>
          </div>
        </div>
        <div class="split-layout__media">
          {%- if section.settings.philosophy_image != blank -%}
            <img src="{{ section.settings.philosophy_image | image_url: width: 800 }}" alt="" width="800" height="800" loading="lazy" class="about-media-img">
          {%- else -%}
            <div class="about-media-placeholder" style="background: var(--color-bg-cream, #F5ECD7);"></div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <!-- 6. PRODUCT THINKING -->
  <section class="about-thinking section-padding">
    <div class="container container--narrow">
      <div class="about-thinking__content">
        <h2 class="about-section-title text-center">{{ section.settings.thinking_title }}</h2>
        <div class="thinking-blocks">
          {{ section.settings.thinking_text }}
        </div>
      </div>
    </div>
  </section>

  <!-- 7. EXPERIENCE -->
  <section class="about-experience">
    <div class="about-experience__media">
      {%- if section.settings.experience_image != blank -%}
        <img src="{{ section.settings.experience_image | image_url: width: 1440 }}" alt="" width="1440" height="600" loading="lazy" class="about-experience__img">
      {%- else -%}
        <div class="about-experience__placeholder" style="background: var(--color-bg-cream, #F5ECD7);"></div>
      {%- endif -%}
    </div>
    <div class="about-experience__content section-padding">
      <div class="container container--narrow text-center">
        <p class="about-experience__text">{{ section.settings.experience_text | newline_to_br }}</p>
      </div>
    </div>
  </section>

  <!-- 8. TRUST STRIP -->
  <section class="about-trust">
    <div class="container">
      <div class="trust-strip">
        <div class="trust-strip__item">Sulfate-free</div>
        <div class="trust-strip__item">Cruelty-free</div>
        <div class="trust-strip__item">Made in India</div>
      </div>
    </div>
  </section>

  <!-- 9. SOFT CTA -->
  <section class="about-cta section-padding">
    <div class="container text-center">
      <h2 class="about-cta__title">{{ section.settings.cta_title }}</h2>
      <div class="about-cta__actions">
        <a href="{{ routes.all_products_collection_url }}/cleansing-bars" class="btn btn--primary">{{ section.settings.cta_button_1 }}</a>
        <a href="{{ routes.collections_url }}/combo-offers" class="btn btn--outline">{{ section.settings.cta_button_2 }}</a>
      </div>
      
      <!-- Micro founder line -->
      {%- if section.settings.founder_line != blank -%}
        <p class="about-cta__micro">{{ section.settings.founder_line | newline_to_br }}</p>
      {%- endif -%}
    </div>
  </section>

</div>

<style>
/* Base Styles */
.about-page {
  background-color: var(--color-bg-page, #F3E8E4);
  color: var(--mm-dark-espresso, #2E1F1A);
  font-family: var(--font-body);
}

.section-padding {
  padding: 80px 0;
}

.container--narrow {
  max-width: 800px;
  margin: 0 auto;
}

.text-center {
  text-align: center;
}

.about-section-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 400;
  line-height: 1.2;
  color: var(--mm-deep-garnet, #4B2A31);
  margin-bottom: 24px;
}

.about-section-text {
  font-size: clamp(1rem, 1.5vw, 1.15rem);
  line-height: 1.8;
  color: var(--mm-dark-espresso, #2E1F1A);
  opacity: 0.9;
}

.about-section-text p {
  margin-bottom: 1.5rem;
}

/* 1. HERO */
.about-hero {
  position: relative;
  min-height: 70vh;
  display: flex;
  align-items: center;
  padding: 80px 0;
  text-align: center;
}

.about-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.about-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.8;
}

.about-hero__placeholder {
  width: 100%;
  height: 100%;
}

.about-hero__content {
  position: relative;
  z-index: 1;
  max-width: 800px;
  margin: 0 auto;
  background: rgba(243, 232, 228, 0.85);
  padding: 60px 40px;
  border-radius: 16px;
  backdrop-filter: blur(8px);
}

.about-hero__title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 300;
  line-height: 1.1;
  color: var(--mm-deep-garnet, #4B2A31);
  margin-bottom: 20px;
}

.about-hero__subtext {
  font-size: clamp(1rem, 2vw, 1.25rem);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--mm-dark-espresso, #2E1F1A);
  opacity: 0.8;
}

/* 2. BRAND INTENT */
.about-intent__text {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  line-height: 1.4;
  font-weight: 400;
  text-align: center;
  color: var(--mm-deep-garnet, #4B2A31);
  max-width: 700px;
  margin: 0 auto;
}

/* Split Layouts (Problem & Philosophy) */
.split-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.split-layout--reverse .split-layout__content {
  order: 2;
}

.split-layout--reverse .split-layout__media {
  order: 1;
}

.about-media-img {
  width: 100%;
  height: auto;
  border-radius: 12px;
  box-shadow: 0 4px 30px rgba(0,0,0,0.05);
}

.about-media-placeholder {
  width: 100%;
  aspect-ratio: 4/5;
  border-radius: 12px;
}

.about-link {
  display: inline-block;
  margin-top: 24px;
  font-size: 1rem;
  font-weight: 500;
  color: var(--mm-deep-garnet, #4B2A31);
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  transition: opacity 0.3s ease;
}

.about-link:hover {
  opacity: 0.7;
}

/* 4. THE APPROACH */
.approach-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
}

.approach-card {
  text-align: left;
  padding: 40px;
  background: var(--color-bg-cream, #F5ECD7);
  border-radius: 12px;
}

.approach-card__title {
  font-family: var(--font-display);
  font-size: 1.75rem;
  color: var(--mm-deep-garnet, #4B2A31);
  margin-bottom: 16px;
  font-weight: 400;
}

.approach-card__text {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--mm-dark-espresso, #2E1F1A);
  opacity: 0.85;
}

/* 6. PRODUCT THINKING */
.about-thinking {
  background: var(--color-bg-cream, #F5ECD7);
  border-radius: 24px;
  margin: 0 20px;
}

.thinking-blocks {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 3vw, 2rem);
  line-height: 1.6;
  text-align: center;
  color: var(--mm-dark-espresso, #2E1F1A);
}

/* 7. EXPERIENCE */
.about-experience {
  margin-top: 80px;
}

.about-experience__media {
  width: 100%;
  height: 60vh;
  min-height: 400px;
}

.about-experience__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.about-experience__placeholder {
  width: 100%;
  height: 100%;
}

.about-experience__text {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  line-height: 1.4;
  color: var(--mm-deep-garnet, #4B2A31);
}

/* 8. TRUST STRIP */
.about-trust {
  padding: 40px 0;
  border-top: 1px solid rgba(46, 31, 26, 0.1);
  border-bottom: 1px solid rgba(46, 31, 26, 0.1);
}

.trust-strip {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 40px;
}

.trust-strip__item {
  font-family: var(--font-body);
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--mm-dark-espresso, #2E1F1A);
  display: flex;
  align-items: center;
  gap: 8px;
}

.trust-strip__item::before {
  content: '✦';
  color: var(--mm-champagne-gold, #D4AF37);
  font-size: 1.2em;
}

/* 9. SOFT CTA */
.about-cta__title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--mm-deep-garnet, #4B2A31);
  margin-bottom: 32px;
  font-weight: 400;
}

.about-cta__actions {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 40px;
}

.about-cta__micro {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-style: italic;
  color: var(--mm-dark-espresso, #2E1F1A);
  opacity: 0.7;
  max-width: 600px;
  margin: 0 auto;
}

/* RESPONSIVE */
@media (max-width: 900px) {
  .split-layout {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  
  .split-layout--reverse .split-layout__content {
    order: 1;
  }
  
  .split-layout--reverse .split-layout__media {
    order: 2;
  }
  
  .approach-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}

@media (max-width: 600px) {
  .section-padding {
    padding: 60px 0;
  }
  
  .about-hero__content {
    padding: 40px 20px;
    margin: 0 20px;
  }
  
  .about-cta__actions {
    flex-direction: column;
    padding: 0 20px;
  }
  
  .about-cta__actions .btn {
    width: 100%;
  }
  
  .trust-strip {
    gap: 20px;
    flex-direction: column;
  }
}
</style>

{% schema %}
{
