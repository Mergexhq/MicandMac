{% comment %}
  Section: Main Product (PDP)
  Orchestrates all PDP snippets in correct order.
  Replaces the thin product.liquid stub.
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign avg_rating = product.metafields.reviews.rating.value
  assign review_count = product.metafields.reviews.rating_count.value
-%}

<div class="pdp section-padding">
  <div class="container">
    <div class="pdp__layout">

      <!-- Left: Gallery -->
      <div class="pdp__gallery">
        {% render 'product-gallery', product: product %}
      </div>

      <!-- Right: Content -->
      <div class="pdp__content">

        <!-- Breadcrumb -->
        {% render 'breadcrumb' %}

        <!-- Vendor -->
        {%- if product.vendor != blank and section.settings.show_vendor -%}
          <p class="pdp__vendor eyebrow">{{ product.vendor }}</p>
        {%- endif -%}

        <!-- Title -->
        <h1 class="pdp__title">{{ product.title }}</h1>

        <!-- Rating -->
        {%- if avg_rating != blank -%}
          <div class="pdp__rating">
            {% render 'star-rating', rating: avg_rating, count: review_count, size: 'md' %}
          </div>
        {%- endif -%}

        <!-- Price -->
        <div class="pdp__price" id="PdpPrice">
          {% render 'price', variant: current_variant %}
        </div>

        <!-- Short description -->
        {%- if product.metafields.custom.short_description != blank -%}
          <p class="pdp__short-desc">{{ product.metafields.custom.short_description }}</p>
        {%- endif -%}

        <!-- Product Form -->
        {% render 'product-form', product: product, section: section %}

        <!-- Trust strip -->
        {% render 'product-trust' %}

        <!-- Tabs -->
        {% render 'product-tabs', product: product %}

        <!-- Reviews -->
        {% render 'product-reviews', product: product %}

      </div>
    </div>
  </div>
</div>

<!-- Sticky ATC -->
{% render 'sticky-atc', product: product %}

<!-- Product Ingredients Deep Dive (section — add to template JSON) -->
{% section 'product-ingredients' %}

<!-- Related Products -->
{%- if section.settings.show_related -%}
  <div class="container">
    {%- assign product_id_for_recommendations = product.id -%}
    <div
      data-related-products
      data-product-id="{{ product_id_for_recommendations }}"
      data-limit="4"
      id="RelatedProductsContainer"
    ></div>
  </div>
{%- endif -%}

<!-- Recently Viewed (populated by recently-viewed.ts) -->
<section class="recently-viewed section-padding--sm" id="RecentlyViewedSection" style="display:none">
  <div class="container">
    <h2 style="font-family:var(--font-display);font-size:var(--text-2xl);font-weight:400;margin-bottom:var(--space-6)">Recently Viewed</h2>
    <div class="product-grid" id="RecentlyViewedGrid"
         style="grid-template-columns:repeat(4,1fr)"></div>
  </div>
</section>

<style>
.pdp__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: start;
}

.pdp__vendor {
  margin-bottom: var(--space-2);
}

.pdp__title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 400;
  color: var(--color-text-dark);
  line-height: 1.2;
  margin-bottom: var(--space-4);
}

.pdp__rating {
  margin-bottom: var(--space-4);
}

.pdp__price {
  margin-bottom: var(--space-5);
}

.pdp__price .price__current {
  font-size: var(--text-2xl);
}

.pdp__short-desc {
  font-size: var(--text-base);
  color: var(--color-text-mid);
  line-height: 1.7;
  margin-bottom: var(--space-5);
}

@media (max-width: 767px) {
  .pdp__layout {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
}
</style>

{% schema %}
{
  "name": "Main product",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Show Buy Now button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_notify_me",
      "label": "Show notify-me form for sold-out variants",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Show related products below",
      "default": true
    }
  ]
}
{% endschema %}
