{% # sections/product.liquid %}

<style>
  .product-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: var(--page-width);
    margin: 40px auto;
    padding: 0 var(--page-margin);
  }

  .product__gallery {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .product__image {
    width: 100%;
    border-radius: var(--radius);
    background: #f7f7f7;
  }

  .product__info {
    position: sticky;
    top: 100px;
    height: fit-content;
  }

  .product__badges {
    display: flex;
    gap: 10px;
    margin-bottom: 16px;
  }

  .badge {
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 700;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
  }

  .badge--gold { background: var(--color-accent); color: var(--color-primary); }
  .badge--green { background: var(--color-highlight); color: var(--color-primary); }

  .product__title { margin-bottom: 8px; }

  .product__price {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 24px;
    color: var(--color-text);
  }

  .product-form {
    margin-bottom: 32px;
  }

  .product-form select {
    width: 100%;
    margin-bottom: 16px;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: var(--radius);
  }

  .atc-button {
    width: 100%;
    padding: 16px;
    font-size: 18px;
    background-color: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    font-weight: 600;
  }

  .product__ingredients {
    margin-top: 40px;
    padding: 24px;
    background: var(--color-soft);
    border-radius: var(--radius);
  }

  .product__ingredients h3 { margin-bottom: 12px; }

  .trust-icons {
    display: flex;
    justify-content: space-between;
    margin-top: 40px;
    opacity: 0.7;
    font-size: 14px;
    border-top: 1px solid #eee;
    padding-top: 24px;
  }

  @media (max-width: 991px) {
    .product-page {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

<div class="product-page">
  
  <div class="product__gallery">
    {% for image in product.images %}
      {{ image | image_url: width: 1000 | image_tag: class: 'product__image', loading: 'lazy', alt: image.alt }}
    {% endfor %}
  </div>

  <div class="product__info">
    <div class="product__badges">
      {% if product.tags contains 'Bestseller' %}
        <span class="badge badge--gold">⭐ Bestseller</span>
      {% endif %}
      <span class="badge badge--green">🌿 100% Natural</span>
    </div>

    <h1 class="product__title">{{ product.title }}</h1>
    
    <div class="product__price">
      {{ product.selected_or_first_available_variant.price | money }}
    </div>
    
    <div class="product-form">
      {% form 'product', product %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        {% if product.variants.size > 1 %}
          <select name="variant_id" onchange="this.form.id.value = this.value">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }} - {{ variant.price | money }}
              </option>
            {% endfor %}
          </select>
        {% endif %}
        
        <button type="submit" class="atc-button" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
        </button>
      {% endform %}
    </div>

    <div class="product__description">
      {{ product.description }}
    </div>

    {% if product.metafields.custom.key_ingredients != blank %}
      <div class="product__ingredients">
        <h3>Key Ingredients</h3>
        {{ product.metafields.custom.key_ingredients | metafield_tag }}
      </div>
    {% endif %}
    
    <div class="trust-icons">
      <span>🌿 Paraben Free</span>
      <span>🐰 Cruelty Free</span>
      <span>♻️ Eco Packaging</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured Product",
  "settings": [],
  "presets": [{ "name": "Featured Product" }]
}
{% endschema %}
