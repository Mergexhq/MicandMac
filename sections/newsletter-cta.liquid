{% comment %}
  Section: Newsletter + WhatsApp CTA
  - Burgundy background · email signup · WhatsApp community button
  - Klaviyo form ID setting
{% endcomment %}

<section
  class="newsletter-cta"
  style="background: {{ section.settings.bg_color | default: '#800020' }};"
>
  <div class="container">
    <div class="newsletter-cta__inner">

      <!-- Left: copy -->
      <div class="newsletter-cta__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow" style="color: var(--color-gold)">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="newsletter-cta__heading">{{ section.settings.heading | default: 'Join the Glow Club' }}</h2>
        <p class="newsletter-cta__subtext">{{ section.settings.subtext | default: 'Get skincare tips, early access to launches & 10% off your first order.' }}</p>
      </div>

      <!-- Right: forms -->
      <div class="newsletter-cta__forms">

        <!-- Email -->
        {%- form 'customer', class: 'newsletter-form', id: 'NewsletterForm-{{ section.id }}' -%}
          <input type="hidden" name="contact[tags]" value="newsletter,glow-club">
          <div class="newsletter-form__row">
            <input
              type="email"
              name="contact[email]"
              class="newsletter-form__input"
              placeholder="{{ section.settings.email_placeholder | default: 'Enter your email' }}"
              autocomplete="email"
              aria-label="Email address"
              required
            >
            <button type="submit" class="btn btn--gold">
              {{ section.settings.cta_label | default: 'Get 10% Off' }}
            </button>
          </div>
          {%- if form.errors -%}
            <p class="newsletter-form__msg newsletter-form__msg--error">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          {%- if form.posted_successfully? -%}
            <p class="newsletter-form__msg newsletter-form__msg--success">🎉 You're in! Check your inbox for your code.</p>
          {%- endif -%}
          <p class="newsletter-form__disclaimer">No spam. Unsubscribe any time.</p>
        {%- endform -%}

        {%- if section.settings.show_whatsapp and section.settings.whatsapp_url != blank -%}
          <div class="newsletter-cta__divider">
            <span>or</span>
          </div>
          <a
            href="{{ section.settings.whatsapp_url }}"
            class="whatsapp-btn"
            target="_blank"
            rel="noopener"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Join our WhatsApp Community
          </a>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<style>
.newsletter-cta {
  padding-block: var(--space-16);
  color: var(--color-white);
}

.newsletter-cta__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: center;
}

.newsletter-cta__copy .eyebrow {
  margin-bottom: var(--space-3);
}

.newsletter-cta__heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 300;
  color: var(--color-white);
  margin-bottom: var(--space-4);
  line-height: 1.2;
}

.newsletter-cta__subtext {
  font-size: var(--text-base);
  color: rgba(255,255,255,0.75);
  line-height: 1.7;
}

.newsletter-form__row {
  display: flex;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}

.newsletter-form__input {
  flex: 1;
  height: 52px;
  padding: 0 var(--space-5);
  background: rgba(255,255,255,0.12);
  border: 1.5px solid rgba(255,255,255,0.25);
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
  font-size: var(--text-base);
  color: var(--color-white);
  outline: none;
  transition: border-color var(--transition-fast);
}

.newsletter-form__input::placeholder { color: rgba(255,255,255,0.45); }

.newsletter-form__input:focus {
  border-color: var(--color-gold);
}

.newsletter-form__disclaimer {
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.4);
  margin-top: var(--space-2);
}

.newsletter-form__msg {
  font-size: var(--text-sm);
  margin-top: var(--space-2);
}

.newsletter-form__msg--error   { color: #ffb3b3; }
.newsletter-form__msg--success { color: #aaeecc; }

.newsletter-cta__divider {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  color: rgba(255,255,255,0.3);
  font-size: var(--text-sm);
  margin: var(--space-4) 0;
}

.newsletter-cta__divider::before,
.newsletter-cta__divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,0.15);
}

.whatsapp-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  width: 100%;
  padding: var(--space-4) var(--space-6);
  background: #25D366;
  color: var(--color-white);
  border-radius: var(--radius-pill);
  font-size: var(--text-sm);
  font-weight: 500;
  letter-spacing: 0.03em;
  text-decoration: none;
  transition: all var(--transition-base);
}

.whatsapp-btn:hover {
  background: #128C7E;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(37, 211, 102, 0.3);
}

@media (max-width: 767px) {
  .newsletter-cta__inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .newsletter-form__row {
    flex-direction: column;
  }

  .newsletter-form__input {
    width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Newsletter + WhatsApp CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Exclusive Members"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Glow Club"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Get skincare tips, early access to launches & 10% off your first order."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Subscribe button label",
      "default": "Get 10% Off"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#800020"
    },
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp",
      "label": "Show WhatsApp button",
      "default": true
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp community link"
    }
  ],
  "presets": [
    {
      "name": "Newsletter + WhatsApp CTA"
    }
  ]
}
{% endschema %}
