{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="trust-bar bg-{{ section.settings.color_scheme }} section-{{ section.id }}-padding border-y border-gray-200" id="TrustBar-{{ section.id }}">
  <div class="container px-4">
    <div class="flex flex-wrap items-center justify-center gap-6 md:gap-12 lg:gap-24 text-center">
      {%- for block in section.blocks -%}
        <div class="trust-bar__item flex flex-col items-center max-w-[120px]" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <span class="trust-bar__icon text-2xl lg:text-3xl mb-2 text-primary" aria-hidden="true">{{ block.settings.icon }}</span>
          {%- elsif block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 60 }}" alt="" width="30" height="30" class="mb-2" loading="lazy">
          {%- endif -%}
          <span class="trust-bar__text text-xs md:text-sm font-medium tracking-wide uppercase">{{ block.settings.title }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "gray-50",
          "label": "Light Gray"
        },
        {
          "value": "primary-light",
          "label": "Primary Light"
        }
      ],
      "default": "gray-50",
      "label": "Color Scheme"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji/Text Icon",
          "default": "🌿"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image Icon (Overrides Emoji)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "100% Natural"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "🌿", "title": "Vegan & Natural" } },
        { "type": "trust_item", "settings": { "icon": "🐰", "title": "Cruelty Free" } },
        { "type": "trust_item", "settings": { "icon": "🇮🇳", "title": "Made in India" } },
        { "type": "trust_item", "settings": { "icon": "♻️", "title": "Sustainable" } }
      ]
    }
  ]
}
{% endschema %}
