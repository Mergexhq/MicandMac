{% comment %}
  Section: Main Collection (Hybrid Editorial PLP)
  Implements the 7-Stage Hybrid Flow:
  1. Hero, 2. Quick Scan, 3. Featured Prod, 4. Editorial List, 5. Mini Grid, 6. Brand Paragraph, 7. Visual Close
{% endcomment %}

{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 16
-%}

<div class="main-collection hybrid-plp">
  
  {%- paginate collection.products by products_per_page -%}
  
    {%- if paginate.current_page == 1 -%}
      <!-- Stage 1 & 2: Hero & Quick Scan -->
      <div class="plp-simple-hero section-padding">
        <div class="container text-center">
          <div class="plp-simple-hero__subline" style="font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 15px; color: var(--mm-dark-espresso); font-weight: 500;">Formulated for lasting care.</div>
          <h1 class="plp-simple-hero__title">The Collection</h1>
          <div class="plp-simple-hero__desc">
            From cleansing bars to nourishing balms, each blend is crafted to restore balance and elevate the everyday.
          </div>
        </div>
      </div>

      <div class="plp-quick-scan">
        <div class="container container--narrow">
          <ul class="plp-quick-list">
            {%- if section.settings.quick_links != blank -%}
              {%- for link in linklists[section.settings.quick_links].links -%}
                <li><a href="{{ link.url }}" class="plp-quick-link {% if link.active %}is-active{% endif %}">{{ link.title }}</a></li>
              {%- endfor -%}
            {%- else -%}
              {%- assign all_url = routes.all_products_collection_url -%}
              {%- assign current_tag_list = current_tags | join: ' ' | downcase -%}
              <li><a href="{{ all_url }}" class="plp-quick-link {% if request.path == all_url and current_tags == blank %}is-active{% endif %}">All</a></li>
              <li><a href="{{ all_url }}/cleansing-bar" class="plp-quick-link {% if current_tag_list contains 'cleansing' or current_tag_list contains 'bar' or current_tag_list contains 'soap' %}is-active{% endif %}">Cleansing Bars</a></li>
              <li><a href="{{ all_url }}/lip-care" class="plp-quick-link {% if current_tag_list contains 'lip' %}is-active{% endif %}">Lip Care</a></li>
            {%- endif -%}
          </ul>
        </div>
      </div>
    {%- endif -%} <!-- Close Hero/Scan if -->

    <!-- Stage 5: Mini Grid (Quick Shop) -->
    <div class="plp-mini-grid-section section-padding bg-murmur">
      <div class="container">
      {% comment %} Filter bar removed as per minimalist request {% endcomment %}

        {%- if collection.products.size > 0 -%}
          <div class="product-grid" style="row-gap: 60px;">
            {%- for product in collection.products -%}
              {%- assign is_combo = false -%}
              {%- assign p_check_title = product.title | downcase -%}
              {%- assign p_check_type = product.type | downcase -%}
              {%- assign p_check_tags = product.tags | join: ' ' | downcase -%}
              {%- if p_check_title contains 'combo' or p_check_type contains 'combo' or p_check_tags contains 'combo' -%}
                {%- assign is_combo = true -%}
              {%- endif -%}

              {%- if is_combo -%}
                {%- continue -%}
              {%- endif -%}

              {%- comment -%} Shopify naturally filters collection.products when a tag is in the URL. 
                  However, we add a safety check just in case we are using custom logic. 
              {%- endcomment -%}
              {%- if current_tags.size > 0 -%}
                {%- assign match = false -%}
                {%- assign c_tags = current_tags | join: ' ' | downcase -%}
                {%- assign p_search = product.title | append: ' ' | append: product.type | append: ' ' | append: product.tags | join: ' ' | downcase -%}
                {%- if c_tags contains 'cleansing' or c_tags contains 'bar' -%}
                  {%- if p_search contains 'soap' or p_search contains 'bar' or p_search contains 'cleansing' -%}
                    {%- assign match = true -%}
                  {%- endif -%}
                {%- elsif c_tags contains 'lip' -%}
                  {%- if p_search contains 'lip' or p_search contains 'balm' -%}
                    {%- assign match = true -%}
                  {%- endif -%}
                {%- else -%}
                  {%- for tag in current_tags -%}
                    {%- assign t = tag | downcase -%}
                    {%- if p_search contains t -%}
                      {%- assign match = true -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
                {%- if match -%}
                  {% render 'product-card', product: product %}
                {%- endif -%}
              {%- else -%}
                {% render 'product-card', product: product %}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="collection-empty text-center" style="padding: 100px 0;">
            <p style="margin-bottom: 20px;">No products found in this collection.</p>
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary">Shop All</a>
          </div>
        {%- endif -%}

        {% render 'pagination', paginate: paginate %}
      </div>
    </div>

    {%- if paginate.current_page == 1 -%}
      <!-- Promoted Combos Recommendation Layer -->
      {%- assign combo_count = 0 -%}
      {%- capture combo_html -%}
        {%- for combo in collections.all.products -%}
          {%- assign c_title = combo.title | downcase -%}
          {%- assign c_type = combo.type | downcase -%}
          {%- assign c_tags = combo.tags | join: ' ' | downcase -%}
          {%- if c_title contains 'combo' or c_type contains 'combo' or c_tags contains 'combo' -%}
            {%- assign combo_count = combo_count | plus: 1 -%}
            <div class="plp-combo-row">
              <div class="plp-combo-row__image-wrap">
                <a href="{{ combo.url }}" class="plp-combo-img-link">
                  {%- if combo.featured_image -%}
                    <img src="{{ combo.featured_image | image_url: width: 800 }}" alt="{{ combo.title | escape }}" loading="lazy" class="plp-combo-row__img" width="{{ combo.featured_image.width }}" height="{{ combo.featured_image.height }}">
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'plp-combo-row__img' }}
                  {%- endif -%}
                </a>
              </div>
              <div class="plp-combo-row__info">
                <h3 class="plp-combo-row__title">
                  <a href="{{ combo.url }}">{{ combo.title | split: '|' | first }}</a>
                </h3>
                <p class="plp-combo-row__desc">
                  {{ combo.metafields.custom.benefit | default: "Thoughtfully formulated to restore natural balance and provide profound, lasting nourishment." }}
                </p>

                <div class="plp-combo-row__pricing">
                  <span class="plp-combo-row__price--sale">{{ combo.price | money }}</span>
                  {%- if combo.compare_at_price > combo.price -%}
                    <span class="plp-combo-row__price--regular">{{ combo.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>

                <div class="plp-combo-row__actions">
                  <form method="post" action="{{ routes.cart_add_url }}" class="plp-combo__atc">
                    <input type="hidden" name="id" value="{{ combo.variants.first.id }}">
                    <button type="submit" class="btn btn--primary plp-btn" {% unless combo.available %}disabled{% endunless %}>
                      {% if combo.available %}Add to Bag{% else %}Sold Out{% endif %}
                    </button>
                  </form>
                  <a href="{{ combo.url }}" class="btn btn--secondary plp-btn">View Details</a>
                </div>

                <div class="plp-combo-row__includes">
                  <p class="plp-combo-row__includes-title">Includes:</p>
                  {%- if combo.metafields.custom.includes != blank -%}
                    {%- assign includes_arr = combo.metafields.custom.includes | newline_to_br | split: '<br />' -%}
                    <ul class="plp-combo-row__includes-list">
                      {%- for item in includes_arr -%}
                        {%- assign trimmed = item | strip -%}
                        {%- if trimmed != blank -%}<li>&bull; {{ trimmed }}</li>{%- endif -%}
                      {%- endfor -%}
                    </ul>
                  {%- else -%}
                    <ul class="plp-combo-row__includes-list">
                      <li>&bull; Artisanal Cleansing Bar</li>
                      <li>&bull; Nourishing Lip Balm</li>
                    </ul>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
          {%- if combo_count >= 2 -%}{%- break -%}{%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if combo_count > 0 -%}
        <div class="plp-curated-combos section-padding" style="padding-top: 120px; padding-bottom: 80px;">
          <div class="container">
            
            <div class="text-center" style="margin-bottom: 80px;">
              <h2 style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(2.5rem, 4vw, 3.2rem); font-weight: 500; color: var(--mm-deep-garnet); margin-bottom: 12px; line-height: 1.1;">Designed to Work Together</h2>
              <p style="font-size: 0.95rem; letter-spacing: 0.05em; color: var(--mm-dark-espresso); opacity: 0.7;">Thoughtfully paired formulations for enhanced daily care.</p>
            </div>

            <div class="plp-combo-list">
              {{ combo_html }}
            </div>
          </div>
        </div>
      {%- endif -%}

      <!-- Stage 6: Brand Paragraph -->
      {%- if section.settings.brand_text != blank -%}
      <div class="plp-brand-paragraph section-padding text-center">
        <div class="container container--narrow">
          <h2 class="plp-brand-heading">{{ section.settings.brand_heading }}</h2>
          <div class="plp-brand-text">{{ section.settings.brand_text }}</div>
        </div>
      </div>
      {%- endif -%}

      <!-- Stage 7: Visual Close -->
      {%- if section.settings.closing_image != blank -%}
      <div class="plp-visual-close">
        <img src="{{ section.settings.closing_image | image_url: width: 2500 }}" alt="Closing Aesthetic" width="{{ section.settings.closing_image.width }}" height="{{ section.settings.closing_image.height }}" class="plp-visual-close__img" loading="lazy">
      </div>
      {%- endif -%}
    {%- endif -%} <!-- Final Page 1 check -->

  {%- endpaginate -%}
</div>

<style>
  /* Hybrid PLP Specific CSS */
  .plp-simple-hero {
    padding-top: var(--space-20);
    padding-bottom: var(--space-8);
    background-color: var(--mm-soft-blush);
  }
  .plp-simple-hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 500;
    margin-bottom: var(--space-4);
    color: var(--mm-deep-garnet);
    line-height: 1.1;
  }
  .plp-simple-hero__desc {
    font-size: clamp(14px, 2vw, 17px);
    color: var(--mm-dark-espresso);
    line-height: 1.6;
    letter-spacing: 0.02em;
    max-width: 100%;
    margin: 0 auto;
    opacity: 0.85;
  }
  
  /* Quick Scan Strip */
  .plp-quick-scan {
    background-color: var(--mm-soft-blush);
    padding: var(--space-4) 0 var(--space-12) 0;
  }
  .plp-quick-list {
    display: flex;
    justify-content: center;
    gap: var(--space-12);
    list-style: none;
    padding: 0;
    margin: 0;
    overflow-x: auto;
    scrollbar-width: none;
    align-items: baseline;
  }
  .plp-quick-list::-webkit-scrollbar { display: none; }
  .plp-quick-link {
    display: inline-block;
    color: var(--mm-dark-espresso);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2vw, 1.95rem);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    opacity: 0.35;
    padding: 5px 10px;
    transition: all var(--transition-fast);
  }
  .plp-quick-link sup {
    font-size: 0.35em;
    vertical-align: super;
    margin-left: 2px;
    opacity: 0.7;
    font-weight: 500;
  }
  .plp-quick-link:hover {
    opacity: 0.8;
    background: transparent;
  }
  .plp-quick-link.is-active {
    opacity: 1;
    color: var(--mm-deep-garnet);
    font-weight: 600;
    background: transparent;
    border: none;
  }

  /* Curated Combos Layer */
  .plp-combo-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-20);
  }
  .plp-combo-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: flex-start;
  }
  @media (max-width: 767px) {
    .plp-combo-row {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
  .plp-combo-row__image-wrap {
    width: 100%;
    margin: 0;
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(46, 31, 26, 0.08); /* Surface shadow for premium weight */
  }
  .plp-combo-row__img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3; /* Implements landscape proportion */
    object-fit: cover;
    display: block;
  }
  .plp-combo-row__info {
    padding-right: var(--space-8);
  }
  .plp-combo-row__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 500;
    color: var(--mm-deep-garnet);
    margin-bottom: var(--space-3);
    line-height: 1.1;
  }
  .plp-combo-row__title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s;
  }
  .plp-combo-row__title a:hover {
    color: var(--mm-terracotta-rose);
  }
  .plp-combo-row__desc {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--mm-dark-espresso);
    opacity: 0.8;
    margin-bottom: var(--space-4);
    line-height: 1.6;
    max-width: 100%;
  }
  .plp-combo-row__pricing {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }
  .plp-combo-row__price--sale {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--mm-deep-garnet);
  }
  .plp-combo-row__price--regular {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    color: #888;
    text-decoration: line-through;
  }
  .plp-combo-row__actions {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    max-width: 100%;
  }
  .plp-combo-row__actions > * {
    flex: 1;
  }
  .plp-combo-row__actions form {
    margin: 0;
    padding: 0;
  }
  .plp-combo-row__actions .plp-btn {
    width: 100%;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 15px;
    font-size: 0.8rem;
    border-radius: 0 !important;
    box-sizing: border-box;
    margin: 0;
    line-height: 1;
  }
  .plp-combo-row__includes {
    border-top: 1px solid rgba(46, 31, 26, 0.1);
    padding-top: var(--space-4);
    max-width: 100%;
  }
  .plp-combo-row__includes-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mm-dark-espresso);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .plp-combo-row__includes-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .plp-combo-row__includes-list li {
    font-size: 0.95rem;
    color: var(--mm-dark-espresso);
    opacity: 0.85;
    margin-bottom: 4px;
  }

  /* Mini Grid (Stage 5) */
  .bg-murmur { 
    background-color: var(--mm-soft-blush);
    border-top: 1px solid rgba(46,31,26,0.05);
  }
  .plp-mini-grid__header {
    margin-bottom: var(--space-10);
  }
  .plp-mini-grid__heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: var(--mm-deep-garnet);
    margin-bottom: var(--space-1);
  }
  .plp-mini-grid__sub {
    font-size: 11px;
    color: var(--mm-dark-espresso);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0.6;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  /* Product Card styling now lives in assets/product-card.css */
  
  /* Brand Paragraph (Stage 6) */
  .plp-brand-paragraph {
    background: var(--mm-soft-blush);
  }
  .plp-brand-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.5rem;
    color: var(--mm-deep-garnet);
    margin-bottom: var(--space-4);
    font-weight: 500;
  }
  .plp-brand-text {
    font-size: 16px;
    color: var(--mm-dark-espresso);
    line-height: 1.8;
  }

  /* Visual Close (Stage 7) */
  .plp-visual-close__img {
    width: 100%;
    height: 70vh;
    object-fit: cover;
    display: block;
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .plp-split-layout, .plp-editorial-row {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .plp-editorial-row--reverse {
      direction: ltr;
    }
    .plp-editorial-row__info {
      padding: 0;
      text-align: center;
    }
    .plp-featured__info {
      text-align: center;
    }
    .plp-actions {
      margin: 0 auto;
    }
    .plp-editorial-row__title {
      font-size: 2rem;
    }
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }

  @media (min-width: 769px) and (max-width: 1023px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Hybrid Collection PLP",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "link_list",
      "id": "quick_links",
      "label": "Quick Scan Categories",
      "info": "Select a menu to show category links below the hero."
    },
    {
      "type": "text",
      "id": "brand_heading",
      "label": "Brand Paragraph Heading",
      "default": "The Art of Wellness"
    },
    {
      "type": "richtext",
      "id": "brand_text",
      "label": "Brand Paragraph Text",
      "default": "<p>Discover the finest artisanal ingredients crafted to restore, nourish, and elevate your daily ritual.</p>"
    },
    {
      "type": "image_picker",
      "id": "closing_image",
      "label": "Visual Close Image",
      "info": "Large aesthetic image to anchor the bottom of the page."
    }
  ]
}
{% endschema %}
