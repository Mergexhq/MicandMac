{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="hero-banner relative flex items-center justify-center overflow-hidden min-h-[70vh] md:min-h-[85vh] bg-gray-900 section-{{ section.id }}-padding" id="HeroBanner-{{ section.id }}">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.image.alt | escape }}"
      class="absolute inset-0 w-full h-full object-cover object-center z-0"
      width="2000"
      height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | round }}"
      fetchpriority="high"
    >
  {%- endif -%}
  
  {%- if section.settings.video_url != blank -%}
    <video class="absolute inset-0 w-full h-full object-cover z-0" autoplay loop muted playsinline>
      <source src="{{ section.settings.video_url }}" type="video/mp4">
    </video>
  {%- endif -%}

  <!-- Overlay -->
  <div class="absolute inset-0 z-10" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

  <div class="container relative z-20 text-center px-4 md:px-8 max-w-4xl text-white">
    {%- if section.settings.subheading != blank -%}
      <p class="text-sm md:text-base font-medium tracking-widest uppercase mb-4" style="color: {{ section.settings.text_color_secondary }};">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}
    
    {%- if section.settings.heading != blank -%}
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-light leading-tight mb-6" style="color: {{ section.settings.text_color }}; font-family: var(--font-display);">
        {{ section.settings.heading }}
      </h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="text-lg md:text-xl font-light mb-8 max-w-2xl mx-auto" style="color: {{ section.settings.text_color_secondary }};">
        {{ section.settings.text }}
      </div>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--lg inline-block">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background Video URL (MP4)",
      "info": "Overrides image if provided"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color_secondary",
      "label": "Text Color",
      "default": "#e5e7eb"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
