{% comment %}
  Section: Hero Banner
  - Full-screen hero with image or video
  - Eyebrow + headline + subtext + CTA
  - Customizable via theme editor
{% endcomment %}

<section class="hero {% if section.settings.full_height %}hero--full{% endif %}"
  style="
    {% if section.settings.overlay_opacity > 0 %}--overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};{% endif %}
    {% if section.settings.text_color == 'light' %}--hero-text: #FFFFFF;{% else %}--hero-text: #1C2B25;{% endif %}
  "
>

  <!-- Background Media -->
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      <video autoplay muted loop playsinline class="hero__video">
        <source src="{{ section.settings.video }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        srcset="
          {{ section.settings.image | image_url: width: 640 }} 640w,
          {{ section.settings.image | image_url: width: 1024 }} 1024w,
          {{ section.settings.image | image_url: width: 1600 }} 1600w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        class="hero__img"
      >
    {%- else -%}
      <div class="hero__placeholder"></div>
    {%- endif -%}

    <!-- Overlay -->
    <div class="hero__overlay"></div>
  </div>

  <!-- Content -->
  <div class="container">
    <div class="hero__content hero__content--{{ section.settings.text_align }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="hero__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      <div class="hero__ctas">
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link }}" class="btn btn--primary btn--lg">
            {{ section.settings.cta_text }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta2_text != blank -%}
          <a href="{{ section.settings.cta2_link }}" class="btn btn--ghost btn--lg">
            {{ section.settings.cta2_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  {%- if section.settings.show_scroll_indicator -%}
    <div class="hero__scroll">
      <span>Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  {%- endif -%}

</section>

<style>
.hero {
  position: relative;
  min-height: 600px;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero--full {
  min-height: 100svh;
}

.hero__media {
  position: absolute;
  inset: 0;
}

.hero__img,
.hero__video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.hero__placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--color-forest) 0%, var(--color-forest-light) 50%, var(--color-sage) 100%);
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(28, 43, 37, var(--overlay, 0.35));
}

.hero__content {
  position: relative;
  z-index: 2;
  max-width: 680px;
  padding-block: var(--space-20);
  color: var(--hero-text, #1C2B25);
}

.hero__content--center {
  margin-inline: auto;
  text-align: center;
}

.hero__content--right {
  margin-left: auto;
}

.hero__eyebrow {
  color: var(--color-gold-light);
  margin-bottom: var(--space-4);
  animation: fadeIn 0.6s ease 0.1s both;
}

.hero__heading {
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 300;
  color: inherit;
  line-height: 1.05;
  margin-bottom: var(--space-6);
  animation: fadeIn 0.6s ease 0.2s both;
}

.hero__subtext {
  font-size: clamp(1rem, 2vw, var(--text-xl));
  color: inherit;
  opacity: 0.85;
  margin-bottom: var(--space-8);
  line-height: 1.7;
  animation: fadeIn 0.6s ease 0.3s both;
}

.hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  animation: fadeIn 0.6s ease 0.4s both;
}

.hero__content--center .hero__ctas {
  justify-content: center;
}

/* Scroll indicator */
.hero__scroll {
  position: absolute;
  bottom: var(--space-8);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  color: rgba(255,255,255,0.6);
  font-size: var(--text-xs);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  z-index: 2;
  animation: fadeIn 0.6s ease 0.8s both;
}

.hero__scroll-line {
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.4);
  position: relative;
  overflow: hidden;
}

.hero__scroll-line::after {
  content: '';
  position: absolute;
  top: -40px;
  left: 0;
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.9);
  animation: scrollLine 1.5s ease-in-out infinite;
}

@keyframes scrollLine {
  to { top: 40px; }
}

@media (max-width: 767px) {
  .hero__ctas { flex-direction: column; }
  .hero__ctas .btn { width: 100%; justify-content: center; }
  .hero--full { min-height: 90svh; }
}
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "video",
      "label": "Video URL (MP4)",
      "info": "Hosted video URL. Leave blank to use image."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 70,
      "step": 5,
      "default": 35,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Clean. Natural. Honest."
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty That's Good For You"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "100% natural ingredients. No hidden chemicals. Formulated for Indian skin & climate."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta2_text",
      "label": "Secondary button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta2_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "options": [
        { "value": "light", "label": "Light (for dark images)" },
        { "value": "dark",  "label": "Dark (for light images)" }
      ],
      "default": "light"
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full screen height",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
