{% comment %}Section: Main Account Dashboard{% endcomment %}

{%- assign active_section = request.param_last | default: '' -%}

<div class="account-page">
  <div class="container">
    <div class="account-page__layout">

      <!-- ── Sidebar ────────────────────────────── -->
      <aside class="account-page__sidebar">
        {%- if active_section == 'details' -%}
          {% render 'account-nav', current: 'details' %}
        {%- else -%}
          {% render 'account-nav', current: 'orders' %}
        {%- endif -%}
      </aside>

      <!-- ── Main Content ────────────────────────── -->
      <main class="account-page__main">

        {%- if active_section == 'details' -%}

          <!-- ═══════════════════════════════════
               ACCOUNT DETAILS
               ═══════════════════════════════════ -->
          <div class="acct-header">
            <h1 class="acct-header__title">Account details</h1>
            <p class="acct-header__subtitle">Your personal information</p>
          </div>

          {%- form 'customer' -%}
            <div class="address-form-wrap">

              {%- if form.errors -%}
                <div style="background:#fff4f4;border:1px solid #f5c0c0;border-radius:8px;padding:12px 16px;font-size:0.8rem;color:#8B2020;margin-bottom:1.5rem;">
                  {{ form.errors | default_errors }}
                </div>
              {%- endif -%}

              <div class="form-row">
                <div class="form-group">
                  <label for="AccountFirstName" class="form-label">First name</label>
                  <input
                    type="text"
                    id="AccountFirstName"
                    name="customer[first_name]"
                    value="{{ customer.first_name | escape }}"
                    class="form-input"
                    autocomplete="given-name"
                  >
                </div>
                <div class="form-group">
                  <label for="AccountLastName" class="form-label">Last name</label>
                  <input
                    type="text"
                    id="AccountLastName"
                    name="customer[last_name]"
                    value="{{ customer.last_name | escape }}"
                    class="form-input"
                    autocomplete="family-name"
                  >
                </div>
              </div>

              <div class="form-group">
                <label for="AccountEmail" class="form-label">Email</label>
                <input
                  type="email"
                  id="AccountEmail"
                  value="{{ customer.email | escape }}"
                  class="form-input"
                  readonly
                  title="Email cannot be changed here"
                >
              </div>

              <div class="form-group">
                <label for="AccountPhone" class="form-label">Phone <span style="font-weight:400;text-transform:none;letter-spacing:0">(optional)</span></label>
                <input
                  type="tel"
                  id="AccountPhone"
                  name="customer[phone]"
                  value="{{ customer.phone | escape }}"
                  class="form-input"
                  autocomplete="tel"
                  placeholder="+91 XXXXXXXXXX"
                >
              </div>

              <div style="margin-top:0.5rem;display:flex;align-items:center;gap:1.5rem;">
                <button type="submit" class="btn-save" id="AccountDetailsSave">Save changes</button>
                <a
                  href="{{ routes.account_url }}"
                  style="font-size:0.78rem;color:var(--color-text-muted);text-decoration:underline;text-underline-offset:3px;"
                >Cancel</a>
              </div>

            </div>

            <div style="margin-top:1.5rem;padding:1rem 1.25rem;background:#fff;border:1px solid var(--color-border-default);border-radius:12px;display:inline-flex;align-items:center;gap:0.75rem;">
              <span style="font-size:0.78rem;color:var(--color-text-muted);">Want to change your password?</span>
              <a href="/account/reset" style="font-size:0.78rem;font-weight:600;color:var(--color-text-primary);text-decoration:underline;text-underline-offset:3px;">Reset password</a>
            </div>

          {%- endform -%}

        {%- else -%}

          <!-- ═══════════════════════════════════
               ORDERS (Default view)
               ═══════════════════════════════════ -->
          <div class="acct-header">
            <h1 class="acct-header__title">Your orders</h1>
            {%- if customer.orders.size > 0 -%}
              <p class="acct-header__subtitle">{{ customer.orders.size }} order{% if customer.orders.size != 1 %}s{% endif %} placed</p>
            {%- endif -%}
          </div>

          {%- if customer.orders.size > 0 -%}

            <div class="order-list">
              {%- for order in customer.orders -%}
                <div class="order-card">
                  <div class="order-card__info">
                    <p class="order-card__id">Order #{{ order.name }}</p>
                    <div class="order-card__meta">
                      <span>{{ order.created_at | date: '%b %d, %Y' }}</span>
                      <span class="order-card__meta-sep">·</span>
                      <span>{{ order.line_items_count }} item{% if order.line_items_count != 1 %}s{% endif %}</span>
                    </div>
                  </div>

                  {%- assign status = order.fulfillment_status | default: 'unfulfilled' -%}
                  <span class="order-card__status {% if status == 'fulfilled' %}order-card__status--fulfilled{% elsif status == 'processing' %}order-card__status--processing{% endif %}">
                    {{ status | replace: '_', ' ' | capitalize }}
                  </span>

                  <div class="order-card__price">
                    {{ order.total_price | money }}
                    <small>{{ order.financial_status | replace: '_', ' ' | capitalize }}</small>
                  </div>

                  <a href="{{ order.customer_url }}" class="order-card__cta">View details</a>
                </div>
              {%- endfor -%}
            </div>

          {%- else -%}

            <div class="acct-empty">
              <div class="acct-empty__icon">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
              </div>
              <h2 class="acct-empty__title">No orders yet</h2>
              <p class="acct-empty__text">When you place an order, it'll appear here.</p>
              <a href="{{ routes.all_products_collection_url }}" class="btn--outline">Explore products</a>
            </div>

          {%- endif -%}

        {%- endif -%}

      </main>
    </div>
  </div>
</div>

<!-- Toast micro-feedback -->
<div class="acct-toast" id="AcctToast" role="status" aria-live="polite"></div>

<script>
(function () {
  /* Toast helper */
  const toast = document.getElementById('AcctToast');
  function showToast(msg) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('is-visible');
    setTimeout(() => toast.classList.remove('is-visible'), 3000);
  }

  /* Account details save feedback */
  const saveBtn = document.getElementById('AccountDetailsSave');
  if (saveBtn) {
    saveBtn.closest('form').addEventListener('submit', function () {
      showToast('Saving…');
    });
  }

  /* Flash success if redirected back */
  if (window.location.search.includes('customer_updated=true')) {
    showToast('Details saved successfully.');
  }
})();
</script>

{% schema %}
{
  "name": "Account Dashboard",
  "settings": []
}
{% endschema %}
