{% comment %}
  Section: Main 404
  Standard error page for page not found.
{% endcomment %}

<div class="main-404 section-padding">
  <div class="container text-center">
    <p class="main-404__num">404</p>
    
    <h1 class="main-404__title">Page Not Found</h1>
    <p class="main-404__text">
      {{ section.settings.message | default: "Sorry, the page you're looking for doesn't exist or has been moved." }}
    </p>

    <div class="main-404__actions">
      <a href="{{ routes.root_url }}" class="btn btn--primary btn--lg">Go Home</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary btn--lg">Shop All</a>
    </div>
  </div>
</div>

<style>
  .main-404 { 
    text-align: center; 
    min-height: 65vh; 
    display: flex; 
    align-items: center; 
    position: relative;
  }
  
  .main-404 .container { 
    width: 100%; 
  }

  .main-404__num {
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 14rem);
    font-weight: 300;
    /* Updated to Burgundy (Deep Garnet) with a soft opacity */
    color: var(--mm-deep-garnet);
    opacity: 0.08;
    line-height: 0.9;
    margin: -3rem 0 -2rem 0;
    letter-spacing: -0.02em;
    pointer-events: none;
  }

  .main-404__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    color: var(--mm-deep-garnet);
    margin-bottom: var(--space-4);
    letter-spacing: -0.01em;
    position: relative;
    z-index: 2;
  }

  .main-404__text { 
    color: var(--mm-dark-espresso); 
    opacity: 0.8;
    margin-bottom: var(--space-10); 
    max-width: 520px; 
    margin-inline: auto; 
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .main-404__actions { 
    display: flex; 
    justify-content: center; 
    gap: var(--space-4); 
    flex-wrap: wrap; 
  }

  /* Override global pill buttons with square-rounded corners for 404 page */
  .main-404 .btn {
    border-radius: var(--radius-md) !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    min-width: 180px;
  }
</style>

{% schema %}
{
  "name": "404 page",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Sorry, the page you're looking for doesn't exist or has been moved."
    }
  ]
}
{% endschema %}
