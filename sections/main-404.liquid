{% comment %}Section: 404{% endcomment %}

<div class="main-404 section-padding">
  <div class="container text-center">
    <p class="main-404__num">404</p>
    <h1 class="main-404__title">Page not found</h1>
    <p class="main-404__text">The page may have been moved or doesn’t exist.</p>
    <div class="main-404__actions">
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--lg">Explore products</a>
    </div>
    <div class="main-404__search">
      <form action="{{ routes.search_url }}" method="get" class="search-results__form-row">
        <input type="search" name="q" class="form-input" placeholder="Search products…" aria-label="Search" style="max-width:320px">
        <button type="submit" class="btn btn--primary">Search</button>
      </form>
    </div>
  </div>
</div>

<meta http-equiv="refresh" content="3;url={{ routes.root_url }}">

<style>
.main-404 { text-align:center; min-height:60vh; display:flex; align-items:center; }
.main-404 .container { width:100%; }
.main-404__num {font-family:var(--font-display);font-size:clamp(6rem,20vw,14rem);font-weight:300;color:var(--color-beige);line-height:1;margin-bottom:var(--space-2);}
.main-404__title {font-family:var(--font-display);font-size:clamp(1.75rem,4vw,3rem);font-weight:300;color:var(--color-text-dark);margin-bottom:var(--space-4);}
.main-404__text {color:var(--color-text-mid);margin-bottom:var(--space-8);max-width:480px;margin-inline:auto;}
.main-404__actions {display:flex;justify-content:center;gap:var(--space-4);margin-bottom:var(--space-8);}
.main-404__search {display:flex;flex-direction:column;align-items:center;gap:var(--space-3);color:var(--color-text-light);font-size:var(--text-sm);}
.main-404__search .search-results__form-row {gap:var(--space-2);}
</style>

{% schema %}
{
  "name": "404 page",
  "settings": []
}
{% endschema %}


<div class="main-404 section-padding">
  <div class="container text-center">
    <p class="main-404__num">404</p>
    <h1 class="main-404__title">Page Not Found</h1>
    <p class="main-404__text">{{ section.settings.message | default: "Sorry, the page you're looking for doesn't exist or has been moved." }}</p>
    <div class="main-404__actions">
      <a href="{{ routes.root_url }}" class="btn btn--primary btn--lg">Go Home</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary btn--lg">Shop All</a>
    </div>
    <div class="main-404__search">
      <p>Or try searching:</p>
      <form action="{{ routes.search_url }}" method="get" class="search-results__form-row">
        <input type="search" name="q" class="form-input" placeholder="Search products…" aria-label="Search" style="max-width:320px">
        <button type="submit" class="btn btn--primary">Search</button>
      </form>
    </div>
  </div>
</div>

<style>
.main-404 { text-align: center; min-height: 60vh; display: flex; align-items: center; }
.main-404 .container { width: 100%; }
.main-404__num {
  font-family: var(--font-display);
  font-size: clamp(6rem, 20vw, 14rem);
  font-weight: 300;
  color: var(--color-beige);
  line-height: 1;
  margin-bottom: var(--space-2);
}
.main-404__title {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 4vw, 3rem);
  font-weight: 300;
  color: var(--color-text-dark);
  margin-bottom: var(--space-4);
}
.main-404__text { color: var(--color-text-mid); margin-bottom: var(--space-8); max-width: 480px; margin-inline: auto; }
.main-404__actions { display: flex; justify-content: center; gap: var(--space-4); margin-bottom: var(--space-8); flex-wrap: wrap; }
.main-404__search { display: flex; flex-direction: column; align-items: center; gap: var(--space-3); color: var(--color-text-light); font-size: var(--text-sm); }
.main-404__search .search-results__form-row { gap: var(--space-2); }
</style>

{% schema %}
{
  "name": "404 page",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Sorry, the page you're looking for doesn't exist or has been moved."
    }
  ]
}
{% endschema %}
