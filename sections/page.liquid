{% comment %}
  This section is used in the page template to render store pages like About us
  or Contact us.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}

<div class="container section-padding">
  <div class="page-header" style="text-align: center; margin-bottom: var(--space-8);">
    <h1 class="page-title font-display">{{ page.title }}</h1>
  </div>
  <div class="rte" style="max-width: 800px; margin: 0 auto;">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}
