{% comment %}
  Section: Main Cart - High Conversion Funnel
{% endcomment %}

<div class="main-cart section-padding">
  <div class="container container--wide">

    {%- if cart.item_count > 0 -%}
      <div class="main-cart__layout">
        
        <!-- =======================
             LEFT COLUMN: ITEMS & UPSELL
             ======================= -->
        <div class="main-cart__left">
          <div class="main-cart__header-mobile">
            <h1 class="main-cart__title">Your Cart</h1>
          </div>

          <div class="main-cart__items-wrap">
            <h1 class="main-cart__title desktop-only">Your Cart</h1>

            <div class="main-cart__items" id="CartItems">
              {%- form 'cart', cart, id: 'CartForm' -%}
                {%- for item in cart.items -%}
                  <div class="cart-card" data-key="{{ item.key }}">
                    
                    <a href="{{ item.url }}" class="cart-card__img-wrapper">
                      {%- if item.image -%}
                        <img
                          src="{{ item.image | image_url: width: 240 }}"
                          alt="{{ item.title | escape }}"
                          width="120"
                          height="120"
                          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                          {% if forloop.first %}fetchpriority="high"{% endif %}
                          class="cart-card__img"
                        >
                      {%- else -%}
                        <div class="cart-card__img-placeholder"></div>
                      {%- endif -%}
                    </a>

                    <div class="cart-card__details">
                      <div class="cart-card__info-top">
                        <a href="{{ item.url }}" class="cart-card__title">{{ item.product.title }}</a>
                        <p class="cart-card__benefit">
                          {{ item.product.metafields.custom.benefits_line | default: 'Deep cleansing &bull; Detoxifying' }}
                        </p>
                      </div>

                      <div class="cart-card__price-wrapper">
                        <span class="cart-card__price">{{ item.final_line_price | money }}</span>
                      </div>

                      <div class="cart-card__actions">
                        <div class="qty-control">
                          <button type="button" class="qty-btn" data-cart-qty-minus="{{ item.key }}" aria-label="Decrease quantity">
                            &minus;
                          </button>
                          <input
                            type="number"
                            name="updates[]"
                            id="updates_{{ item.key }}"
                            data-qty-input="{{ item.key }}"
                            value="{{ item.quantity }}"
                            min="0"
                            class="qty-field"
                            aria-label="Item quantity"
                          >
                          <button type="button" class="qty-btn" data-cart-qty-plus="{{ item.key }}" aria-label="Increase quantity">
                            &#43;
                          </button>
                        </div>
                        <button type="button" class="cart-card__remove" data-cart-remove="{{ item.key }}" aria-label="Remove item">Remove</button>
                      </div>
                    </div>

                  </div>
                {%- endfor -%}
              {%- endform -%}
            </div>
          </div>

          <!-- MICRO UPSELL STRIP -->
          {%- if section.settings.upsell_product != blank -%}
            {%- assign upsell_item = all_products[section.settings.upsell_product] -%}
            {%- if upsell_item != blank and upsell_item.available -%}
              {%- assign in_cart = false -%}
              {%- for item in cart.items -%}
                {%- if item.product.handle == upsell_item.handle -%}{%- assign in_cart = true -%}{%- break -%}{%- endif -%}
              {%- endfor -%}

              {%- unless in_cart -%}
              <div class="cart-upsell-strip">
                <h3 class="cart-upsell-strip__title">{{ section.settings.upsell_heading | default: 'Complete your care' }}</h3>
                <div class="cart-upsell-strip__box">
                  <div class="cart-upsell-strip__info">
                    {% if upsell_item.featured_image %}
                      <img src="{{ upsell_item.featured_image | image_url: width: 80 }}" alt="{{ upsell_item.title | escape }}" width="40" height="40" loading="lazy" style="border-radius:6px;object-fit:cover;"/>
                    {% elsif upsell_item.images.size > 0 %}
                      <img src="{{ upsell_item.images[0] | image_url: width: 80 }}" alt="{{ upsell_item.title | escape }}" width="40" height="40" loading="lazy" style="border-radius:6px;object-fit:cover;"/>
                    {% else %}
                      <div style="width:40px;height:40px;background:#f0e3db;border-radius:4px;"></div>
                    {% endif %}
                    <div class="cart-upsell-strip__text">
                      <strong>{{ upsell_item.title }}</strong>
                      <span>{{ upsell_item.price | money }}</span>
                    </div>
                  </div>
                  <form method="post" action="/cart/add" class="cart-upsell-strip__form">
                    <input type="hidden" name="id" value="{{ upsell_item.variants.first.id }}">
                    <button type="submit" class="btn-upsell-add">Add</button>
                  </form>
                </div>
              </div>
              {%- endunless -%}
            {%- endif -%}
          {%- else -%}
            <!-- Auto upsell: pick a product not already in cart -->
            {%- assign found_upsell = false -%}
            {%- for p in collections['all'].products limit: 20 -%}
              {%- if found_upsell -%}{%- break -%}{%- endif -%}
              {%- assign already_in = false -%}
              {%- for item in cart.items -%}
                {%- if item.product.handle == p.handle -%}{%- assign already_in = true -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
              {%- unless already_in -%}
                {%- if p.available -%}
                  {%- assign found_upsell = true -%}
                  <div class="cart-upsell-strip">
                    <h3 class="cart-upsell-strip__title">Complete your care</h3>
                    <div class="cart-upsell-strip__box">
                      <div class="cart-upsell-strip__info">
                        {%- if p.featured_image -%}
                          <img src="{{ p.featured_image | image_url: width: 120 }}" alt="{{ p.title | escape }}" width="40" height="40" loading="lazy" style="border-radius:6px;object-fit:cover;">
                        {%- else -%}
                          <div style="width:40px;height:40px;background:#f0e3db;border-radius:4px;"></div>
                        {%- endif -%}
                        <div class="cart-upsell-strip__text">
                          <strong>{{ p.title }}</strong>
                          <span>{{ p.price | money }}</span>
                        </div>
                      </div>
                      <form method="post" action="/cart/add" class="cart-upsell-strip__form">
                        <input type="hidden" name="id" value="{{ p.variants.first.id }}">
                        <button type="submit" class="btn-upsell-add">Add</button>
                      </form>
                    </div>
                  </div>
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}

        </div>

        <!-- =======================
             RIGHT COLUMN: SUMMARY
             ======================= -->
        <div class="main-cart__right">
          <div class="summary-card">
            <h2 class="summary-card__title">Order Summary</h2>

            <!-- Free Shipping Incentive -->
            {%- liquid
              assign threshold = section.settings.threshold_cents | default: 99900
              assign cart_total = cart.total_price
              assign remaining = threshold | minus: cart_total
            -%}
            <div class="summary-incentive">
              {%- if remaining > 0 -%}
                <span class="incentive-msg">Add <strong>{{ remaining | money }}</strong> more for free shipping</span>
                <div class="incentive-track"><div class="incentive-fill" style="width: {{ cart_total | times: 100 | divided_by: threshold }}%"></div></div>
              {%- else -%}
                <span class="incentive-msg incentive-msg--success">✓ You unlocked free shipping</span>
                <div class="incentive-track"><div class="incentive-fill" style="width: 100%"></div></div>
              {%- endif -%}
            </div>

            <div class="summary-rows">
              <div class="summary-row">
                <span>Subtotal</span>
                <span id="CartSubtotal">{{ cart.total_price | money }}</span>
              </div>
              <div class="summary-row summary-row--shipping">
                <span>Shipping</span>
                <span>Calculated at checkout</span>
              </div>
              
              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="summary-row summary-row--discount">
                    <span>{{ discount.title }}</span>
                    <span>–{{ discount.total_allocated_amount | money }}</span>
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </div>

            <div class="summary-total">
              <span>Total</span>
              <span id="CartTotal">{{ cart.total_price | money }}</span>
            </div>

            <!-- Desktop explicit checkout button -->
            <a href="/checkout" class="btn btn--primary btn--full summary-checkout-btn" style="border-radius: var(--radius-sm);">Proceed to Checkout</a>

            <!-- Trust Badges -->
            <ul class="summary-trust">
              <li>
                <svg width="16" height="16" fill="none" class="trust-icon" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 6L9 17l-5-5"/></svg>
                Orders dispatch within 48 hrs
              </li>
              <li>
                <svg width="16" height="16" fill="none" class="trust-icon" viewBox="0 0 24 24"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"/></svg>
                Secure checkout
              </li>
            </ul>

          </div>
        </div>
      </div>

    {%- else -%}
      <!-- EMPTY STATE -->
      <div class="cart-empty-state">
        <h2 class="cart-empty-state__title">Your cart is waiting.</h2>
        <a href="{{ routes.all_products_collection_url }}" class="cart-empty-state__link">Explore our essentials &rarr;</a>
      </div>
    {%- endif -%}

  </div>
</div>

<!-- =======================
     MOBILE STICKY CHECKOUT
     ======================= -->
{%- if cart.item_count > 0 -%}
<div class="mobile-sticky-checkout">
  <div class="mobile-sticky-checkout__inner">
    <a href="/checkout" class="btn btn--primary btn--full" style="border-radius: var(--radius-sm);">Proceed to Checkout &bull; {{ cart.total_price | money }}</a>
  </div>
</div>
{%- endif -%}

<style>
/* ── CART VARIABLES & BASE ── */
.main-cart {
  background-color: #F8F5F2;
  min-height: 70vh;
}

.container--wide {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-4);
}

.main-cart__title {
  font-family: var(--font-heading-family, serif);
  font-size: clamp(2rem, 5vw, 2.5rem);
  font-weight: 300;
  color: #2D2321;
  margin-bottom: 2rem;
  line-height: 1.1;
}

/* ── LAYOUT ── */
.main-cart__layout {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 4rem;
  align-items: start;
}

/* Base hides */
.desktop-only { display: block; }
.main-cart__header-mobile { display: none; }

/* ── LEFT COLUMN (ITEMS) ── */
.cart-card {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 2rem;
  background: #FFFFFF;
  border-radius: 12px;
  padding: 1.5rem;
  margin-bottom: 1rem;
  align-items: center;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
}

.cart-card__img-wrapper {
  display: block;
  width: 100px;
  height: 100px;
  border-radius: 8px;
  overflow: hidden;
  background: #fdfdfd;
}

.cart-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.cart-card__details {
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: center;
}

.cart-card__info-top {
  margin-bottom: 0.5rem;
}

.cart-card__title {
  font-family: var(--font-heading-family, serif);
  font-size: 1.25rem;
  font-weight: 500;
  color: #2D2321;
  text-decoration: none;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.2;
}

.cart-card__benefit {
  font-family: var(--font-body-family, sans-serif);
  font-size: 0.8125rem;
  color: #796C69;
  margin-top: 0.25rem;
}

.cart-card__price-wrapper {
  margin-bottom: 1rem;
}

.cart-card__price {
  font-size: 1rem;
  font-weight: 600;
  color: #2D2321;
}

.cart-card__actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-top: auto;
}

.qty-control {
  display: flex;
  align-items: center;
  border: 1px solid #EAE2DB;
  border-radius: 6px;
  height: 36px;
  background: #fff;
}

.qty-btn {
  background: none;
  border: none;
  width: 36px;
  height: 100%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2D2321;
  font-size: 1.25rem;
  font-weight: 300;
}

.qty-field {
  width: 30px;
  height: 100%;
  border: none;
  text-align: center;
  font-size: 0.875rem;
  color: #2D2321;
  -moz-appearance: textfield;
}
.qty-field::-webkit-inner-spin-button, 
.qty-field::-webkit-outer-spin-button { 
  -webkit-appearance: none; 
  margin: 0; 
}

.cart-card__remove {
  background: none;
  border: none;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #928380;
  cursor: pointer;
  text-decoration: none;
  transition: color 0.2s ease;
}
.cart-card__remove:hover { color: #D84242; }

/* ── MICRO UPSELL ── */
.cart-upsell-strip {
  margin-top: 2rem;
  padding: 1.25rem;
  background: #FFFFFF;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
}

.cart-upsell-strip__title {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #796C69;
  margin-bottom: 1rem;
  font-family: var(--font-body-family, sans-serif);
}

.cart-upsell-strip__box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-upsell-strip__info {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.cart-upsell-strip__info img {
  border-radius: 6px;
  background: #f9f9f9;
}

.cart-upsell-strip__text {
  display: flex;
  flex-direction: column;
}

.cart-upsell-strip__text strong {
  font-size: 0.875rem;
  color: #2D2321;
  font-weight: 500;
}

.cart-upsell-strip__text span {
  font-size: 0.8125rem;
  color: #796C69;
}

.btn-upsell-add {
  background: none;
  border: 1px solid #EAE2DB;
  border-radius: 6px;
  padding: 0.5rem 1rem;
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  cursor: pointer;
  color: #2D2321;
  transition: all 0.2s ease;
}
.btn-upsell-add:hover {
  background: #2D2321;
  color: #fff;
  border-color: #2D2321;
}

/* ── RIGHT COLUMN (SUMMARY) ── */
.summary-card {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 2.5rem 2rem;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
  position: sticky;
  top: 100px;
}

.summary-card__title {
  font-family: var(--font-heading-family, serif);
  font-size: 1.5rem;
  font-weight: 300;
  margin-bottom: 2rem;
  color: #2D2321;
}

/* Incentive */
.summary-incentive {
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid #F0EBE6;
}

.incentive-msg {
  display: block;
  font-size: 0.875rem;
  color: #2D2321;
  margin-bottom: 0.75rem;
}

.incentive-msg--success {
  color: #2F7A5B;
  font-weight: 500;
}

.incentive-track {
  width: 100%;
  height: 4px;
  background: #F0EBE6;
  border-radius: 4px;
  overflow: hidden;
}

.incentive-fill {
  height: 100%;
  background: #2D2321;
  border-radius: 4px;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.incentive-msg--success + .incentive-track .incentive-fill {
  background: #2F7A5B;
}

/* Rows */
.summary-rows {
  margin-bottom: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 1rem;
  color: #554A47;
}

.summary-row--shipping {
  font-size: 0.875rem;
  color: #796C69;
}

.summary-row--discount {
  color: #2F7A5B;
}

.summary-total {
  display: flex;
  justify-content: space-between;
  font-size: 1.25rem;
  font-weight: 600;
  color: #2D2321;
  padding-top: 1.5rem;
  border-top: 1px solid #F0EBE6;
  margin-bottom: 2rem;
}

.summary-checkout-btn {
  margin-bottom: 2rem;
}

/* Trust list */
.summary-trust {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.summary-trust li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8125rem;
  color: #796C69;
}

.trust-icon {
  color: #2F7A5B;
}

/* ── EMPTY STATE ── */
.cart-empty-state {
  text-align: center;
  padding: 10vh 0;
}

.cart-empty-state__title {
  font-family: var(--font-heading-family, serif);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 300;
  color: #2D2321;
  margin-bottom: 1.5rem;
}

.cart-empty-state__link {
  font-size: 1rem;
  color: #2D2321;
  text-decoration: underline;
  text-underline-offset: 4px;
  font-weight: 500;
}

/* ── MOBILE STICKY CHECKOUT ── */
.mobile-sticky-checkout {
  display: none;
}

/* ── RESPONSIVE ── */
@media (max-width: 1023px) {
  .main-cart__layout {
    grid-template-columns: 1fr;
    gap: 2rem;
  }
}

@media (max-width: 767px) {
  .main-cart {
    padding-top: 2rem;
    padding-bottom: 120px; /* Space for sticky button */
  }

  .desktop-only { display: none; }
  .main-cart__header-mobile { display: block; margin-bottom: 1.5rem;}
  .main-cart__title { font-size: 2rem; margin-bottom: 0; }

  .cart-card {
    grid-template-columns: 80px 1fr;
    gap: 1.25rem;
    padding: 1rem;
  }
  .cart-card__img-wrapper {
    width: 80px;
    height: 80px;
  }
  
  .cart-card__title { font-size: 1.125rem; }
  
  .cart-upsell-strip__box {
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
  }
  .btn-upsell-add {
    width: 100%;
  }

  .summary-card {
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 1rem;
    position: static;
  }

  .summary-checkout-btn {
    display: none; /* Hidden on mobile in favor of sticky */
  }

  /* Mobile Sticky Implementation */
  .mobile-sticky-checkout {
    display: block;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #FFFFFF;
    padding: 1rem;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.05);
    z-index: 100;
  }
}
</style>

{% schema %}
{
  "name": "Main Cart",
  "settings": [
    {
      "type": "number",
      "id": "threshold_cents",
      "label": "Free Shipping Threshold (in cents)",
      "default": 99900,
      "info": "Example: 100000 for ₹1000"
    },
    {
      "type": "header",
      "content": "Micro Upsell"
    },
    {
      "type": "text",
      "id": "upsell_heading",
      "label": "Heading",
      "default": "Complete your care"
    },
    {
      "type": "product",
      "id": "upsell_product",
      "label": "Upsell Product"
    }
  ]
}
{% endschema %}
