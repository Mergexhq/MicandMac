            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/lip-care" class="mnav__sub-link">
              <span class="mnav__sub-dot"></span>Lip Care
            </a>
          </li>
          <li>
            <a href="{{ routes.collections_url }}/combo-offers" class="mnav__sub-link">
              <span class="mnav__sub-dot"></span>Combos &amp; Offers
