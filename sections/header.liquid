          <span>Instagram</span>
        </a>
        <a href="https://wa.me/919999999999" class="mnav__social-btn" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          <span>WhatsApp</span>
        </a>
        <a href="https://youtube.com/@micandmac" class="mnav__social-btn" target="_blank" rel="noopener" aria-label="YouTube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
          <span>YouTube</span>
        </a>
      </div>
    </div>

    <div class="mnav__divider"></div>

    <!-- ── Brand quote ── -->
    <div class="mnav__brand-quote">
      <p>"Artisan-formulated. Lab-certified.<br>Made in Coimbatore."</p>
    </div>

    <!-- bottom spacer so last item clears dock -->
    <div style="height: 24px;"></div>

  </div><!-- /mnav__body -->

  <!-- Footer: Account actions pinned at bottom -->
  <div class="mnav__footer">
    <a href="{{ routes.account_login_url }}" class="mnav__footer-btn mnav__footer-btn--primary">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Sign In
    </a>
    <a href="{{ routes.account_register_url }}" class="mnav__footer-btn">
      Create Account
    </a>
  </div>

</div><!-- /mnav -->

<!-- Overlay -->
<div class="overlay" id="SiteOverlay"></div>

<!-- =============================================
     MOBILE: Top Bar (mobile only, ≤1023px)
     ============================================= -->
<div class="mobile-topbar" id="MobileTopBar">
  <!-- Left: Hamburger -->
  <button class="mtb__burger" id="NavToggle" aria-label="Open navigation" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <!-- Center: Logo -->
  <a href="{{ routes.root_url }}" class="mtb__logo">
    <img src="{{ 'MicandMac_Monogram.webp' | asset_url }}" alt="Mic &amp; Mac" width="28" height="28" loading="eager">
    <span>MIC &amp; MAC</span>
  </a>

  <!-- Right: Search + Cart -->
  <div class="mtb__actions">
    <button class="mtb__btn" id="SearchToggleMobile" aria-label="Search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    </button>
    <button class="mtb__btn mtb__cart" id="CartToggleMobile" aria-label="Cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      {%- if cart.item_count > 0 -%}
        <span class="mtb__cart-badge" id="MtbCartCount">{{ cart.item_count }}</span>
      {%- else -%}
        <span class="mtb__cart-badge mtb__cart-badge--hidden" id="MtbCartCount"></span>
      {%- endif -%}
    </button>
  </div>
</div>


<!-- =============================================
     DESKTOP: Full Header (≥1024px)
     ============================================= -->
<header class="site-header" id="SiteHeader">

  <!-- Tier 2: Logo strip (Soft Blush bg) -->
  <div class="site-header__middle">
    <div class="container container--fluid">
      <div class="site-header__inner">

        <!-- Left: Tagline (desktop only) -->
        <div class="site-header__tagline">
          <span class="tagline-text">LOVE YOUR SKIN. EVERY DAY. 365.</span>
        </div>

        <!-- Center: Logo -->
        <div class="site-header__logo">
          <a href="{{ routes.root_url }}" class="site-header__logo-link">
            {%- if section.settings.logo != blank -%}
              <img
                src="{{ section.settings.logo | image_url: width: 280 }}"
                alt="{{ shop.name }}"
                width="{{ section.settings.logo_width | default: 160 }}"
                height="auto"
                loading="eager"
                class="site-logo-img"
              >
            {%- else -%}
              <div style="display: flex; align-items: center; gap: 10px;">
                <img src="{{ 'MicandMac_Monogram.webp' | asset_url }}" alt="Mic &amp; Mac Monogram" width="36" height="36" style="object-fit: contain;">
                <span class="site-header__logo-text" style="margin-top: 4px;">MIC &amp; MAC</span>
              </div>
            {%- endif -%}
          </a>
        </div>

        <!-- Right: Action icons (desktop) -->
        <div class="site-header__actions">
          <!-- Search -->
          <button class="site-header__action-btn" id="SearchToggle" aria-label="Search">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
            </svg>
          </button>

          <!-- Wishlist (desktop only) -->
          <a href="/pages/wishlist" class="site-header__action-btn wishlist-btn" aria-label="Wishlist">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </a>

          <!-- Account (Desktop with Dropdown) -->
          <div class="account-menu-wrapper" style="position: relative; display: flex; align-items: center;">
            <a href="{{ routes.account_login_url }}" class="site-header__action-btn" aria-label="Account">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </a>
            <ul class="account-dropdown">
              <div class="account-dropdown-bridge"></div>
              <li><a href="{{ routes.account_login_url }}" class="account-dropdown-link">Sign in</a></li>
              <li><a href="{{ routes.account_register_url }}" class="account-dropdown-link">Create Account</a></li>
              <li><a href="/pages/contact-us" class="account-dropdown-link">Contact Us</a></li>
              <li><a href="/pages/track-order" class="account-dropdown-link">Track Order</a></li>
            </ul>
          </div>

          <!-- Cart -->
          <button class="site-header__action-btn site-header__cart" id="CartToggle" aria-label="Cart">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            {%- if cart.item_count > 0 -%}
              <span class="cart-count" id="CartCount">{{ cart.item_count }}</span>
            {%- else -%}
              <span class="cart-count cart-count--hidden" id="CartCount"></span>
            {%- endif -%}
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- Tier 3: Navigation strip — desktop only -->
  <div class="site-header__bottom">
    <div class="container">
      <nav class="site-nav" aria-label="Main navigation">
        <ul class="site-nav__list">

          <li class="site-nav__item">
            <a href="{{ routes.all_products_collection_url }}" class="site-nav__link site-nav__link--white{% if request.path == '/collections/all' %} is-active{% endif %}">All Products</a>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <li class="site-nav__item">
            <a href="{{ routes.collections_url }}/face-care" class="site-nav__link{% if request.path contains 'face-care' %} is-active{% endif %}">
              Cleansing Bars
              <svg class="nav-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </a>
            <div class="site-nav__dropdown site-nav__megamenu">
              <div class="site-nav__dropdown-bridge"></div>
              <div class="site-nav__megamenu-left">
                <ul style="list-style: none; padding: 0; margin: 0;">
                  <li><a href="/products/donkey-milk-soap-100gm" class="site-nav__dropdown-link">Donkey Milk Soap</a></li>
                  <li><a href="/products/redwine-soap-100gm" class="site-nav__dropdown-link">Red Wine Radiance</a></li>
                  <li><a href="/products/skjn-whitening-soap-100gm" class="site-nav__dropdown-link">Skin Radiance Glow</a></li>
                  <li class="site-nav__dropdown-divider"></li>
                  <li><a href="{{ routes.collections_url }}/face-care" class="site-nav__dropdown-link" style="font-weight: 600;">Shop All Bars</a></li>
                </ul>
              </div>
              <div class="site-nav__megamenu-right">
                <a href="{{ routes.collections_url }}/face-care" class="site-nav__megamenu-promo">
                  <div class="site-nav__megamenu-promo-img bg-placeholder"></div>
                  <span class="site-nav__megamenu-promo-text">Discover Cleansing Bars</span>
                </a>
              </div>
            </div>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <li class="site-nav__item">
            <a href="{{ routes.collections_url }}/lip-care" class="site-nav__link{% if request.path contains 'lip-care' %} is-active{% endif %}">
              Lip Care
              <svg class="nav-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </a>
            <div class="site-nav__dropdown site-nav__megamenu">
              <div class="site-nav__dropdown-bridge"></div>
              <div class="site-nav__megamenu-left">
                <ul style="list-style: none; padding: 0; margin: 0;">
                  <li><a href="{{ routes.collections_url }}/lip-care" class="site-nav__dropdown-link">Lip Balms</a></li>
                  <li><a href="{{ routes.collections_url }}/lip-care" class="site-nav__dropdown-link">Lip Scrubs</a></li>
                  <li class="site-nav__dropdown-divider"></li>
                  <li><a href="{{ routes.collections_url }}/lip-care" class="site-nav__dropdown-link" style="font-weight: 600;">Shop All Lip Care</a></li>
                </ul>
              </div>
              <div class="site-nav__megamenu-right">
                <a href="{{ routes.collections_url }}/lip-care" class="site-nav__megamenu-promo">
                  <div class="site-nav__megamenu-promo-img bg-placeholder"></div>
                  <span class="site-nav__megamenu-promo-text">Nourish Your Lips</span>
                </a>
              </div>
            </div>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <li class="site-nav__item">
            <a href="{{ routes.collections_url }}/new-arrivals" class="site-nav__link{% if request.path contains 'new-arrivals' %} is-active{% endif %}">New Arrivals</a>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <li class="site-nav__item">
            <a href="{{ routes.collections_url }}/bestsellers" class="site-nav__link{% if request.path contains 'bestsellers' %} is-active{% endif %}">Bestsellers</a>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <li class="site-nav__item">
            <a href="{{ routes.collections_url }}/combo-offers" class="site-nav__link{% if request.path contains 'combo' %} is-active{% endif %}">Combos</a>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <li class="site-nav__item">
            <a href="/pages/about-us" class="site-nav__link{% if request.path contains 'about' %} is-active{% endif %}">Our Story</a>
          </li>

        </ul>
      </nav>
    </div>
  </div>

  <!-- Search bar (slides open) -->
  <div class="site-header__search" id="SearchBar" aria-hidden="true">
    <div class="container">
      <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
        <input type="hidden" name="type" value="product">
        <div class="search-form__inner">
          <input
            class="search-form__input"
            type="search"
            name="q"
            placeholder="Search for skincare, body care..."
            autocomplete="off"
            aria-label="Search"
          >
          <button type="submit" class="search-form__btn" aria-label="Submit search">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
            </svg>
          </button>
          <button type="button" class="search-form__close" id="SearchClose" aria-label="Close search">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>

</header>


<!-- =============================================
     MOBILE: Bottom Dock
     ============================================= -->
<nav class="bottom-dock" id="BottomDock" aria-label="Mobile navigation">
  <a href="{{ routes.root_url }}" class="bdock__item{% if request.path == '/' %} is-active{% endif %}" aria-label="Home">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span>Home</span>
  </a>
