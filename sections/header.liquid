        <li>
          <a href="{{ routes.collections_url }}/best-sellers" class="mnav__flat-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Bestsellers
          </a>
        </li>
        <li>
          <a href="{{ routes.collections_url }}/new-arrivals" class="mnav__flat-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12h14"/></svg>
            New Arrivals
            <span class="mnav__pill mnav__pill--gold">New</span>
          </a>
        </li>
      </ul>
    </div>

    <div class="mnav__divider"></div>

    <!-- ── Direct links: About ── -->
    <div class="mnav__group">
      <p class="mnav__group-label">ABOUT</p>
      <ul class="mnav__flat-links">
        <li><a href="/pages/about-us" class="mnav__flat-link">Our Story</a></li>
        <li><a href="/pages/ingredients" class="mnav__flat-link">Ingredients Philosophy</a></li>
