{% comment %}
  Section: Header — 3-Tier Layout
  - Announcement bar: sits above (separate section)
  - Middle tier: Logo strip on Soft Blush bg
  - Bottom tier: Desktop nav on Deep Garnet bg
  - All CSS lives in assets/base.css
{% endcomment %}

<!-- Mobile Navigation Drawer -->
<div class="mobile-nav" id="MobileNav" aria-hidden="true">
  <div class="mobile-nav__header">
    <a href="{{ routes.root_url }}" class="mobile-nav__logo">MIC & MAC</a>
    <button class="mobile-nav__close" id="NavClose" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <nav class="mobile-nav__nav">
    <ul class="mobile-nav__list">
      <li class="mobile-nav__item">
        <a href="{{ routes.root_url }}" class="mobile-nav__link{% if request.path == '/' %} is-active{% endif %}">Home</a>
      </li>
      <li class="mobile-nav__item">
        <a href="/collections/combo-offers" class="mobile-nav__link{% if request.path contains 'combo' %} is-active{% endif %}">Combo Offers</a>
      </li>
      <li class="mobile-nav__item">
        <a href="/collections/all" class="mobile-nav__link{% if request.path contains 'collections' %} is-active{% endif %}">Best Sellers</a>
        <ul class="mobile-nav__sub">
          <li><a href="/products/donkey-milk-soap-100gm" class="mobile-nav__sub-link">Donkey Milk Soap</a></li>
          <li><a href="/products/redwine-soap-100gm" class="mobile-nav__sub-link">Red Wine Radiance</a></li>
          <li><a href="/products/skjn-whitening-soap-100gm" class="mobile-nav__sub-link">Skin Radiance Glow</a></li>
        </ul>
      </li>
      <li class="mobile-nav__item">
        <a href="/pages/about-us" class="mobile-nav__link{% if request.path contains 'about' %} is-active{% endif %}">About Us</a>
      </li>
      <li class="mobile-nav__item">
        <a href="/pages/contact-us" class="mobile-nav__link{% if request.path contains 'contact' %} is-active{% endif %}">Contact</a>
      </li>
    </ul>
  </nav>
  <div class="mobile-nav__footer">
    <a href="{{ routes.account_url }}" class="mobile-nav__account">My Account</a>
  </div>
</div>

<!-- Overlay -->
<div class="overlay" id="SiteOverlay"></div>

<!-- ===== HEADER ===== -->
<header class="site-header" id="SiteHeader">

  <!-- Tier 2: Logo strip (Soft Blush bg) -->
  <div class="site-header__middle">
    <div class="container">
      <div class="site-header__inner">

        <!-- Mobile: Hamburger -->
        <button class="site-header__burger" id="NavToggle" aria-label="Open navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

        <!-- Left: Tagline (desktop only) -->
        <div class="site-header__tagline">
          <span class="tagline-text">LOVE YOUR SKIN. EVERY DAY. 365.</span>
        </div>

        <!-- Center: Logo -->
        <div class="site-header__logo">
          <a href="{{ routes.root_url }}" class="site-header__logo-link">
            {%- if section.settings.logo != blank -%}
              <img
                src="{{ section.settings.logo | image_url: width: 280 }}"
                alt="{{ shop.name }}"
                width="{{ section.settings.logo_width | default: 160 }}"
                height="auto"
                loading="eager"
                class="site-logo-img"
              >
            {%- else -%}
              <span class="site-header__logo-text">MIC &amp; MAC</span>
            {%- endif -%}
          </a>
        </div>

        <!-- Right: Action icons -->
        <div class="site-header__actions">
          <!-- Search -->
          <button class="site-header__action-btn" id="SearchToggle" aria-label="Search">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
            </svg>
          </button>

          <!-- Wishlist (desktop only) -->
          <a href="/pages/wishlist" class="site-header__action-btn wishlist-btn" aria-label="Wishlist">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </a>

          <!-- Cart -->
          <button class="site-header__action-btn site-header__cart" id="CartToggle" aria-label="Cart">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            {%- if cart.item_count > 0 -%}
              <span class="cart-count" id="CartCount">{{ cart.item_count }}</span>
            {%- else -%}
              <span class="cart-count cart-count--hidden" id="CartCount"></span>
            {%- endif -%}
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- Tier 3: Navigation strip (Deep Garnet bg) — desktop only -->
  <div class="site-header__bottom">
    <div class="container">
      <nav class="site-nav" aria-label="Main navigation">
        <ul class="site-nav__list">

          <!-- Home -->
          <li class="site-nav__item">
            <a href="{{ routes.root_url }}" class="site-nav__link{% if request.path == '/' %} is-active{% endif %}">Home</a>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <!-- Combo Offers -->
          <li class="site-nav__item">
            <a href="/collections/combo-offers" class="site-nav__link{% if request.path contains 'combo' %} is-active{% endif %}">Combo Offers</a>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <!-- Best Sellers (dropdown) -->
          <li class="site-nav__item">
            <a href="/collections/all" class="site-nav__link{% if request.path contains 'collections' %} is-active{% endif %}">
              Best Sellers
              <svg class="nav-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </a>
            <ul class="site-nav__dropdown">
              <div class="site-nav__dropdown-bridge"></div>
              <li>
                <a href="/products/donkey-milk-soap-100gm" class="site-nav__dropdown-link">Donkey Milk Soap</a>
              </li>
              <li>
                <a href="/products/redwine-soap-100gm" class="site-nav__dropdown-link">Red Wine Radiance</a>
              </li>
              <li>
                <a href="/products/skjn-whitening-soap-100gm" class="site-nav__dropdown-link">Skin Radiance Glow</a>
              </li>
            </ul>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <!-- About Us -->
          <li class="site-nav__item">
            <a href="/pages/about-us" class="site-nav__link{% if request.path contains 'about' %} is-active{% endif %}">About Us</a>
          </li>

          <li class="site-nav__separator" aria-hidden="true"><span></span></li>

          <!-- Contact -->
          <li class="site-nav__item">
            <a href="/pages/contact-us" class="site-nav__link{% if request.path contains 'contact' %} is-active{% endif %}">Contact</a>
          </li>

        </ul>
      </nav>
    </div>
  </div>

  <!-- Search bar (slides open) -->
  <div class="site-header__search" id="SearchBar" aria-hidden="true">
    <div class="container">
      <form action="{{ routes.search_url }}" method="get" class="search-form" role="search">
        <input type="hidden" name="type" value="product">
        <div class="search-form__inner">
          <input
            class="search-form__input"
            type="search"
            name="q"
            placeholder="Search for skincare, body care..."
            autocomplete="off"
            aria-label="Search"
          >
          <button type="submit" class="search-form__btn" aria-label="Submit search">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
            </svg>
          </button>
          <button type="button" class="search-form__close" id="SearchClose" aria-label="Close search">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>

</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 80,
      "max": 280,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
