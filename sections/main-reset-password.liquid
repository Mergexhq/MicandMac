{% comment %}Section: Reset Password{% endcomment %}

<div class="account-auth section-padding">
  <div class="container container--xs">
    <h1 class="account-auth__title">Reset Password</h1>
    <p style="text-align:center;margin-bottom:var(--space-6);color:var(--color-text-mid);font-size:var(--text-sm)">
      Enter your email and we'll send you a link to reset your password.
    </p>

    {%- if form.errors -%}
      <div class="form-error" role="alert">{{ form.errors | default_errors }}</div>
    {%- endif -%}

    {%- if form.posted_successfully? -%}
      <p class="account-auth__success">✓ Check your email for a reset link.</p>
    {%- else -%}
      {%- form 'recover_customer_password', id: 'RecoverForm' -%}
        <div class="form-group">
          <label for="RecoverEmail" class="form-label">Email</label>
          <input type="email" id="RecoverEmail" name="email" autocomplete="email" class="form-input" required autofocus>
        </div>
        <button type="submit" class="btn btn--primary btn--full">Send Reset Link</button>
      {%- endform -%}
    {%- endif -%}

    <div class="account-auth__alt">
      <a href="{{ routes.account_login_url }}">← Back to Sign In</a>
    </div>
  </div>
</div>

<style>
.account-auth__success { color: var(--color-forest); text-align: center; font-size: var(--text-base); padding: var(--space-5); background: rgba(0,80,0,0.06); border-radius: var(--radius-md); }
</style>
