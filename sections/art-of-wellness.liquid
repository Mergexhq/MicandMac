{% comment %}
  Section: The Art of Wellness
  A testimonial or product paragraph followed by a large product mockup image.
{% endcomment %}

<div class="art-of-wellness" style="background-color: {{ section.settings.bg_color }};">
  <div class="container text-center">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="aow-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.paragraph != blank -%}
      <div class="aow-paragraph">
        {{ section.settings.paragraph }}
      </div>
    {%- endif -%}

    {%- if section.settings.micro_copy != blank -%}
      <div class="aow-micro-copy">{{ section.settings.micro_copy }}</div>
    {%- endif -%}
    
  </div>

  <div class="aow-image-wrap">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}" 
           alt="{{ section.settings.image.alt | escape }}" 
           width="{{ section.settings.image.width }}" 
           height="{{ section.settings.image.height }}" 
           class="aow-image" 
           loading="lazy">
    {%- else -%}
      {{ 'collection-1' | placeholder_svg_tag: 'aow-image placeholder-svg' }}
    {%- endif -%}
  </div>
</div>

<style>
  .art-of-wellness {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: 0;
  }

  .aow-heading {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: clamp(2rem, 3vw, 2.5rem);
    color: var(--mm-deep-garnet, #2e1f1a);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .aow-paragraph {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    color: var(--mm-dark-espresso, #2e1f1a);
    line-height: 1.3;
    margin: 0 auto 30px auto;
    max-width: 1400px;
    font-weight: 400;
  }

  .aow-paragraph p {
    margin: 0;
  }

  .aow-paragraph em, .aow-paragraph i {
    font-style: italic;
    font-family: var(--font-display, 'Cormorant Garamond', serif);
  }

  .aow-paragraph strong, .aow-paragraph b {
    font-weight: 600;
  }

  .aow-micro-copy {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--mm-dark-espresso, #2e1f1a);
    opacity: 1;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 60px;
  }

  .aow-image-wrap {
    width: 100%;
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  .aow-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .aow-image.placeholder-svg {
    background-color: rgba(0,0,0,0.05);
  }

  @media (max-width: 768px) {
    .aow-paragraph {
      font-size: 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "The Art of Wellness",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f6f3"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Optional small heading above the paragraph"
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Main Paragraph",
      "default": "<p>Formulated with pure ingredients to deliver smoother texture, a healthy glow, and zero harshness.</p>"
    },
    {
      "type": "text",
      "id": "micro_copy",
      "label": "Micro Copy",
      "default": "this is what clean skincare should feel like."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Mockup Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "The Art of Wellness"
    }
  ]
}
{% endschema %}
