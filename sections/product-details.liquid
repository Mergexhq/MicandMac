{% comment %}
  Section: Product Details
  Contains How to use, Social Proof, Combos, FAQ, and Related Products
{% endcomment %}

{%- liquid
  assign how_to_use = product.metafields.custom.how_to_use
-%}

<!-- ============================================================
     SECTION 4: HOW TO USE
     ============================================================ -->
<div class="pdp-how-to-use">
  <div class="container">
    <div class="pdp-how-to-use__layout">
      <div>
        <p class="pdp-how-to-use__eyebrow">Ritual</p>
        <h2 class="pdp-how-to-use__title">How to use</h2>
        <div class="pdp-steps">
          {%- if how_to_use != blank -%}
            {%- assign steps = how_to_use | split: '|' -%}
            {%- for step in steps -%}
              <div class="pdp-step">
                <div class="pdp-step__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
                <p class="pdp-step__text">{{ step | strip }}</p>
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="pdp-step">
              <div class="pdp-step__num">01</div>
              <p class="pdp-step__text">Wet your skin with warm water</p>
            </div>
            <div class="pdp-step">
              <div class="pdp-step__num">02</div>
              <p class="pdp-step__text">Lather the bar gently between hands and massage onto skin in circular motions</p>
            </div>
            <div class="pdp-step">
              <div class="pdp-step__num">03</div>
              <p class="pdp-step__text">Rinse thoroughly and pat dry. Follow with your favourite moisturiser</p>
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- Optional: product image on the right -->
      <div style="display:flex;align-items:center;justify-content:center;">
        {%- if product.media.size > 1 -%}
          <img
            src="{{ product.media[1] | image_url: width: 520 }}"
            alt="{{ product.title | escape }}"
            width="520"
            height="520"
            loading="lazy"
            style="border-radius:var(--radius-lg);object-fit:cover;width:100%;max-width:520px;aspect-ratio:1/1;"
          >
        {%- elsif product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 520 }}"
            alt="{{ product.title | escape }}"
            width="520"
            height="520"
            loading="lazy"
            style="border-radius:var(--radius-lg);object-fit:cover;width:100%;max-width:520px;aspect-ratio:1/1;"
          >
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<!-- ============================================================
     SECTION 5: COMPLETE YOUR ROUTINE (Curated Pairs)
     ============================================================ -->
<div class="pdp-curated-pairs" style="padding: var(--space-12) 0;">
  <div class="container container--narrow" style="max-width: 600px; margin: 0 auto;">
    <div class="pdp-curated-pairs__header" style="margin-bottom: var(--space-8);">
      <h2 class="pdp-curated-pairs__title" style="font-family: var(--font-heading-family, serif); font-size: 2rem; margin-bottom: 8px;">Complete Your Routine</h2>
      <p class="pdp-curated-pairs__subtitle" style="font-size: 1rem; color: #555;">Thoughtfully selected products that work well with this formula.</p>
    </div>

    <div class="pdp-curated-pairs__list">
      {%- liquid
        assign current_title = product.title | downcase
        assign paired_handles = 'donkey-milk-soap,beetroot-lip-balm'

        if current_title contains 'charcoal'
          assign paired_handles = 'donkey-milk-soap,beetroot-lip-balm'
        elsif current_title contains 'lip balm' or current_title contains 'lip-balm'
          assign paired_handles = 'charcoal-soap,red-wine-lip-balm'
        endif
        
        assign paired_array = paired_handles | split: ','
      -%}

      {%- for handle in paired_array -%}
        {%- assign paired_product = all_products[handle] -%}
        {%- if paired_product != blank and paired_product.id != product.id -%}
          <div class="pdp-pair-item" style="display: flex; align-items: center; gap: 1.25rem; border-bottom: 1px solid #eaeaea; padding: 1.5rem 0;">
            <div class="pdp-pair-item__image" style="width: 88px; height: 88px; flex-shrink: 0; background: #fdfdfd; border-radius: 8px; overflow: hidden; border: 1px solid #f3f3f3;">
              <a href="{{ paired_product.url }}">
                <img src="{{ paired_product.featured_image | image_url: width: 176 }}" alt="{{ paired_product.title | escape }}" width="88" height="88" loading="lazy" style="width:100%; height:100%; object-fit:cover; display:block;">
              </a>
            </div>
            <div class="pdp-pair-item__info" style="flex-grow: 1;">
              <a href="{{ paired_product.url }}" style="text-decoration: none; color: inherit;">
                <h4 style="font-family: var(--font-heading-family, serif); font-size: 1.125rem; margin-bottom: 4px;">{{ paired_product.title | split: '|' | first }}</h4>
              </a>
              <p style="font-size: 0.875rem; color: #666; margin-bottom: 12px; line-height: 1.3;">
                {%- if paired_product.metafields.custom.benefits_line != blank -%}
                  {{ paired_product.metafields.custom.benefits_line }}
                {%- else -%}
                  Adds glow + complements deep cleansing
                {%- endif -%}
              </p>
              <div style="display: flex; align-items: center; justify-content: space-between;">
                <span style="font-weight: 500; font-size: 0.9375rem;">{{ paired_product.price | money }}</span>
                <form action="{{ routes.cart_add_url }}" method="post" style="margin:0;">
                  <input type="hidden" name="id" value="{{ paired_product.selected_or_first_available_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" style="background: none; border: none; text-decoration: underline; font-size: 0.8125rem; font-weight: 600; cursor: pointer; padding: 0; text-transform: uppercase; letter-spacing: 0.05em;">Add to bag</button>
                </form>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- ============================================================
     SECTION 6: SOCIAL PROOF (Reviews)
     ============================================================ -->
<div class="container" style="padding-bottom: var(--space-16);">
  {% render 'product-reviews', product: product %}
</div>

{% schema %}
{
  "name": "Product Details",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Product Details"
    }
  ]
}
{% endschema %}
