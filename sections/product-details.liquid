{% comment %}
  Section: Product Details
  Contains How to use, Social Proof, Combos, FAQ, and Related Products
{% endcomment %}

{%- liquid
  assign how_to_use = product.metafields.custom.how_to_use
-%}

<!-- ============================================================
     SECTION 4: HOW TO USE
     ============================================================ -->
<div class="pdp-how-to-use">
  <div class="container">
    <div class="pdp-how-to-use__layout">
      <div>
        <p class="pdp-how-to-use__eyebrow">Ritual</p>
        <h2 class="pdp-how-to-use__title">How to use</h2>
        <div class="pdp-steps">
          {%- if how_to_use != blank -%}
            {%- assign steps = how_to_use | split: '|' -%}
            {%- for step in steps -%}
              <div class="pdp-step">
                <div class="pdp-step__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
                <p class="pdp-step__text">{{ step | strip }}</p>
              </div>
            {%- endfor -%}
          {%- else -%}
            <div class="pdp-step">
              <div class="pdp-step__num">01</div>
              <p class="pdp-step__text">Wet your skin with warm water</p>
            </div>
            <div class="pdp-step">
              <div class="pdp-step__num">02</div>
              <p class="pdp-step__text">Lather the bar gently between hands and massage onto skin in circular motions</p>
            </div>
            <div class="pdp-step">
              <div class="pdp-step__num">03</div>
              <p class="pdp-step__text">Rinse thoroughly and pat dry. Follow with your favourite moisturiser</p>
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- Optional: product image on the right -->
      <div style="display:flex;align-items:center;justify-content:center;">
        {%- if product.media.size > 1 -%}
          <img
            src="{{ product.media[1] | image_url: width: 520 }}"
            alt="{{ product.title | escape }}"
            width="520"
            height="520"
            loading="lazy"
            style="border-radius:var(--radius-lg);object-fit:cover;width:100%;max-width:520px;aspect-ratio:1/1;"
          >
        {%- elsif product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 520 }}"
            alt="{{ product.title | escape }}"
            width="520"
            height="520"
            loading="lazy"
            style="border-radius:var(--radius-lg);object-fit:cover;width:100%;max-width:520px;aspect-ratio:1/1;"
          >
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<!-- ============================================================
     SECTION 5: COMPLETE YOUR ROUTINE (Curated Pairs)
     ============================================================ -->
<div class="pdp-curated-pairs" style="padding: var(--space-16) 0;">
  <div class="container">
    <div class="pdp-curated-pairs__header" style="text-align: center; margin-bottom: var(--space-12);">
      <p class="pdp-how-to-use__eyebrow" style="margin-bottom: 8px;">Build your daily ritual</p>
      <h2 class="pdp-curated-pairs__title" style="font-family: var(--font-heading-family, serif); font-size: 2.5rem; margin-bottom: 8px;">Complete Your Routine</h2>
      <p class="pdp-curated-pairs__subtitle" style="font-size: 1rem; color: #555;">Pairs well with this formulation.</p>
    </div>

    <div class="pdp-curated-pairs__grid">
      {%- liquid
        assign current_title = product.title | downcase
        assign paired_handles = 'donkey-milk-soap,beetroot-lip-balm'

        if current_title contains 'charcoal'
          assign paired_handles = 'donkey-milk-soap,beetroot-lip-balm'
        elsif current_title contains 'lip balm' or current_title contains 'lip-balm'
          assign paired_handles = 'charcoal-soap,red-wine-lip-balm'
        endif
        
        assign paired_array = paired_handles | split: ','
      -%}

      {%- for handle in paired_array -%}
        {%- assign paired_product = all_products[handle] -%}
        {%- if paired_product != blank and paired_product.id != product.id -%}
          <div class="pdp-routine-card">
            <div class="pdp-routine-card__image-wrapper">
              <a href="{{ paired_product.url }}">
                <img src="{{ paired_product.featured_image | image_url: width: 280 }}" alt="{{ paired_product.title | escape }}" loading="lazy" width="280" height="280" class="pdp-routine-card__image">
              </a>
            </div>
            <div class="pdp-routine-card__info">
              <a href="{{ paired_product.url }}" style="text-decoration: none; color: inherit;">
                <h4 style="font-family: var(--font-heading-family, serif); font-size: 1.25rem; margin-bottom: 4px;">{{ paired_product.title | split: '|' | first }}</h4>
              </a>
              <p style="font-size: 0.875rem; color: #666; margin-bottom: 12px; line-height: 1.4;">
                {%- if paired_product.metafields.custom.benefits_line != blank -%}
                  {{ paired_product.metafields.custom.benefits_line }}
                {%- else -%}
                  Deep hydration for everyday care.
                {%- endif -%}
              </p>
              <div style="font-weight: 600; font-size: 1rem; margin-bottom: 16px;">{{ paired_product.price | money }}</div>
              
              <div class="pdp-routine-card__actions">
                <form action="{{ routes.cart_add_url }}" method="post" style="margin:0;">
                  <input type="hidden" name="id" value="{{ paired_product.selected_or_first_available_variant.id }}">
                  <input type="hidden" name="quantity" value="1">
                  <button type="submit" class="pdp-routine-card__btn">Add to Bag</button>
                </form>
                <a href="{{ paired_product.url }}" class="pdp-routine-card__link">View Product &rarr;</a>
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .pdp-curated-pairs__grid {
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); 
    gap: 1.5rem; 
    max-width: 1000px; 
    margin: 0 auto;
  }
  .pdp-routine-card {
    display: flex; 
    align-items: center; 
    gap: 1.5rem; 
    background: #f6eeea; 
    border-radius: 24px; 
    padding: 1.5rem; 
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .pdp-routine-card:hover {
    transform: translateY(-4px);
  }
  .pdp-routine-card__image-wrapper {
    width: 130px; 
    height: 130px; 
    flex-shrink: 0; 
    border-radius: 8px; 
    overflow: hidden;
  }
  .pdp-routine-card__image {
    width: 100%; 
    height: 100%; 
    object-fit: cover; 
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .pdp-routine-card:hover .pdp-routine-card__image {
    transform: scale(1.02);
  }
  .pdp-routine-card__info {
    display: flex; 
    flex-direction: column; 
    flex-grow: 1;
  }
  .pdp-routine-card__actions {
    display: flex; 
    flex-direction: column; 
    gap: 8px;
  }
  .pdp-routine-card__btn {
    width: 100%; 
    padding: 12px 16px; 
    background: var(--mm-deep-garnet, #4b2a31); 
    color: #fffcf5; 
    border: none; 
    border-radius: var(--radius-sm, 4px); 
    font-size: 0.875rem; 
    font-weight: 500; 
    letter-spacing: 0.05em;
    cursor: pointer; 
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .pdp-routine-card__btn:hover {
    transform: translateY(-1px);
  }
  .pdp-routine-card__link {
    font-size: 0.8125rem; 
    font-weight: 500; 
    color: #666; 
    text-decoration: none; 
    text-align: center; 
    padding: 4px 0; 
    transition: color 0.2s ease;
  }
  .pdp-routine-card__link:hover {
    color: #111;
  }
  @media (max-width: 768px) {
    .pdp-curated-pairs__grid {
      grid-template-columns: 1fr;
    }
    .pdp-routine-card {
      padding: 1.25rem;
      gap: 1.25rem;
    }
    .pdp-routine-card__image-wrapper {
      width: 110px;
      height: 110px;
    }
  }
  @media (max-width: 480px) {
    .pdp-routine-card {
      flex-direction: column;
      align-items: flex-start;
    }
    .pdp-routine-card__image-wrapper {
      width: 100%;
      height: 200px;
    }
    .pdp-routine-card__actions {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      gap: 16px;
    }
    .pdp-routine-card__btn {
      width: auto;
      flex-grow: 1;
    }
    .pdp-routine-card__link {
      padding: 10px 0;
    }
  }
</style>

<!-- ============================================================
     SECTION 6: SOCIAL PROOF (Reviews)
     ============================================================ -->
<div class="container" style="padding-bottom: var(--space-16);">
  {% render 'product-reviews', product: product %}
</div>

{% schema %}
{
  "name": "Product Details",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Product Details"
    }
  ]
}
{% endschema %}
